---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Badge from '../../../components/Badge.astro';
import ProductCard from '../../../components/ProductCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import RatingBadge from '../../../components/RatingBadge.astro';
import { loadProducts, localizedTitle, productSlug, type Product } from '@lib/products';
import { productJsonLd } from '@lib/jsonld';
import { loadReviews } from '@lib/reviews';

export function getStaticPaths() {
  return loadProducts().map((p) => ({ params: { slug: productSlug(p, 'tr') }, props: { product: p } }));
}
const { product } = Astro.props as { product: Product };
const gallery = product.images?.length ? product.images : (product.image ? [product.image] : []);
const site = Astro.site!.toString().replace(/\/+$/, '');
const selfPath = `urun/${productSlug(product, 'tr')}`;
const enSlug = productSlug(product, 'en');
const title = localizedTitle(product, 'tr');
const price = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: product.currency }).format(product.price);
const related = loadProducts().filter((x) => x.category === product.category && x.id !== product.id).slice(0, 4);
const ld = productJsonLd(product, 'tr', `${site}/tr/${selfPath}`);
const shop = loadReviews().shop;
---
<Base locale="tr" title={`${title} — Aselovers`} description={product.description_tr || title}
  pathSelf={selfPath} pathsAlt={{ tr: selfPath, en: `product/${enSlug}` }} ogImage={product.image ?? undefined}>
  <Fragment slot="head"><script type="application/ld+json" set:html={ld} /></Fragment>
  <Nav locale="tr" />
  <main>
    <section class="section detail-section">
      <div class="container">
        <nav class="crumbs" aria-label="Sayfa yolu">
          <a href="/tr">Ana sayfa</a><span aria-hidden="true">/</span>
          <a href="/tr/urunler">Ürünler</a><span aria-hidden="true">/</span>
          <span class="crumbs__current">{title}</span>
        </nav>

        <div class="detail">
          <div class="detail__gallery">
            <ProductGallery images={gallery} alt={title} />
          </div>

          <div class="detail__info">
            {product.category && <p class="detail__eyebrow">{product.category}</p>}
            <h1 class="detail__title">{title}</h1>
            <div class="detail__meta">
              <RatingBadge rating={shop.rating} count={shop.count} locale="tr" />
              {product.isNew && <Badge>Yeni</Badge>}
            </div>

            <div class="buybox">
              <div class="buybox__pricerow">
                <span class="detail__price">{price}</span>
                <span class="detail__vat">KDV dahil</span>
                <span class="handmade-tag">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-8-4.5-8-10a4.5 4.5 0 0 1 8-2.8A4.5 4.5 0 0 1 20 11c0 5.5-8 10-8 10z"/></svg>
                  El emeği
                </span>
              </div>

              <div class="stitch" aria-hidden="true">
                <svg viewBox="0 0 240 8" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="7 5"><path d="M2 4 Q10 -1 20 4 T40 4 T60 4 T80 4 T100 4 T120 4 T140 4 T160 4 T180 4 T200 4 T220 4 T238 4"/></svg>
              </div>

              <div class="detail__buy">
                <div class="qtystep" role="group" aria-label="Adet seçimi">
                  <button type="button" class="qtystep__btn" id="qty-minus" aria-label="Adedi azalt">−</button>
                  <span class="qtystep__val" id="qty-val" aria-live="polite">1</span>
                  <button type="button" class="qtystep__btn" id="qty-plus" aria-label="Adedi artır">+</button>
                </div>
                <button id="add-to-cart" type="button" class="btn btn--primary detail__cta" data-product={JSON.stringify(product)}>
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  Sepete Ekle
                </button>
              </div>

              <ul class="assure">
                <li class="assure__item">
                  <span class="assure__ic"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 21s-8-4.5-8-10a4.5 4.5 0 0 1 8-2.8A4.5 4.5 0 0 1 20 11c0 5.5-8 10-8 10z"/></svg></span>
                  <div><strong>El emeği, size özel</strong><span>Her parça siparişe göre tek tek örülür</span></div>
                </li>
                <li class="assure__item">
                  <span class="assure__ic"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg></span>
                  <div><strong>Güvenli ödeme</strong><span>PayTR altyapısı — kart bilgileriniz bizde saklanmaz</span></div>
                </li>
                <li class="assure__item">
                  <span class="assure__ic"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18.5" cy="18.5" r="2"/></svg></span>
                  <div><strong>Özenli kargo</strong><span>Türkiye ve dünya geneline takipli gönderim</span></div>
                </li>
              </ul>
            </div>
          </div>
        </div>

        {product.description_tr && (
          <section class="pdesc">
            <h2 class="pdesc__h">Ürün Açıklaması</h2>
            <div class="pdesc__body prose" style="white-space: pre-line">{product.description_tr}</div>
          </section>
        )}

        {related.length > 0 && (
          <div class="detail__related">
            <h2 class="detail__related-h">Benzer Ürünler</h2>
            <div class="detail__related-grid">{related.map((r) => <ProductCard product={r} locale="tr" />)}</div>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer locale="tr" />

<script>
  import { addToCart, showCartToast } from '@lib/cart';

  let qty = 1;
  const valEl = document.getElementById('qty-val');
  const minus = document.getElementById('qty-minus');
  const plus = document.getElementById('qty-plus');
  const btn = document.getElementById('add-to-cart');

  function render() { if (valEl) valEl.textContent = String(qty); if (minus) (minus as HTMLButtonElement).disabled = qty <= 1; }
  minus?.addEventListener('click', () => { if (qty > 1) { qty--; render(); } });
  plus?.addEventListener('click', () => { if (qty < 99) { qty++; render(); } });
  render();

  btn?.addEventListener('click', () => {
    const raw = btn.getAttribute('data-product');
    if (!raw) return;
    const prod = JSON.parse(raw);
    addToCart(prod, qty);
    showCartToast({ addedLabel: 'Sepete eklendi', goLabel: 'Sepete git', cartHref: '/tr/sepet' });
  });
</script>

  <style>
    .detail-section { padding-top: var(--space-6); }
    .crumbs { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font-size: var(--step-small); color: var(--muted); margin-bottom: var(--space-5); }
    .crumbs a { color: var(--muted); transition: color var(--dur) var(--ease); }
    .crumbs a:hover { color: var(--accent); }
    .crumbs span[aria-hidden] { opacity: .5; }
    .crumbs__current { color: var(--ink); font-weight: 500; max-width: 46ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .detail { display: grid; grid-template-columns: 1.05fr 1fr; gap: var(--space-7); align-items: start; }
    .detail__info { position: sticky; top: 96px; }
    .detail__eyebrow { font-family: var(--font-body); font-size: var(--step-small); letter-spacing: .16em; text-transform: uppercase; color: var(--accent); margin: 0 0 var(--space-2); }
    .detail__title { font-family: var(--font-display); font-size: clamp(1.8rem, 3.2vw, 2.6rem); line-height: 1.12; margin: 0 0 var(--space-3); }
    .detail__meta { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; margin-bottom: var(--space-4); }

    .buybox { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-5); box-shadow: var(--shadow-glass); }
    .buybox__pricerow { display: flex; align-items: baseline; gap: var(--space-3); flex-wrap: wrap; }
    .detail__price { font-family: var(--font-display); font-size: 2.1rem; color: var(--accent-ink); font-feature-settings: "tnum"; line-height: 1; }
    .detail__vat { font-size: var(--step-small); color: var(--muted); }
    .handmade-tag { margin-left: auto; display: inline-flex; align-items: center; gap: 5px; font-size: .68rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, var(--surface)); border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line)); padding: 5px 10px; border-radius: var(--radius-pill); }

    .stitch { color: color-mix(in srgb, var(--accent) 55%, var(--line)); margin: var(--space-4) 0; }
    .stitch svg { display: block; width: 100%; height: 8px; }

    .detail__buy { display: flex; gap: var(--space-3); align-items: stretch; margin-bottom: 0; }
    .qtystep { display: inline-flex; align-items: center; border: 1.5px solid var(--line); border-radius: var(--radius-pill); background: var(--bg); overflow: hidden; flex-shrink: 0; }
    .qtystep__btn { width: 46px; height: 52px; border: none; background: none; font-size: 1.3rem; color: var(--ink); cursor: pointer; transition: background var(--dur) var(--ease), color var(--dur) var(--ease); }
    .qtystep__btn:hover { background: var(--section); color: var(--accent); }
    .qtystep__btn:disabled { opacity: .35; cursor: not-allowed; }
    .qtystep__val { min-width: 34px; text-align: center; font-weight: 600; font-feature-settings: "tnum"; }
    .detail__cta { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 10px; height: 52px; border-radius: var(--radius-pill); font-size: 1rem; font-weight: 600; }
    .detail__cta svg { flex-shrink: 0; }

    .assure { list-style: none; margin: var(--space-4) 0 0; padding: var(--space-4) 0 0; display: grid; gap: var(--space-3); border-top: 1px dashed color-mix(in srgb, var(--accent) 30%, var(--line)); }
    .assure__item { display: flex; align-items: center; gap: var(--space-3); }
    .assure__ic { flex-shrink: 0; width: 36px; height: 36px; display: grid; place-items: center; border-radius: 50%; background: color-mix(in srgb, var(--accent) 9%, var(--surface)); color: var(--accent); }
    .assure__item div { display: flex; flex-direction: column; gap: 1px; }
    .assure__item strong { font-size: .9rem; color: var(--ink); font-weight: 600; }
    .assure__item span { font-size: .82rem; color: var(--muted); line-height: 1.4; }

    .pdesc { margin-top: var(--space-7); padding-top: var(--space-6); border-top: 1px solid var(--line); }
    .pdesc__h { font-family: var(--font-display); font-size: var(--step-h3); margin-bottom: var(--space-4); display: inline-block; padding-bottom: var(--space-2); border-bottom: 2px dashed color-mix(in srgb, var(--accent) 40%, var(--line)); }
    .pdesc__body { max-width: 70ch; color: var(--muted); }

    .detail__related { margin-top: var(--space-8); }
    .detail__related-h { font-family: var(--font-display); font-size: var(--step-h2); margin-bottom: var(--space-5); }
    .detail__related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-5); }

    @media (max-width: 900px) {
      .detail { grid-template-columns: 1fr; gap: var(--space-6); }
      .detail__info { position: static; }
    }
    @media (max-width: 480px) {
      .detail__buy { flex-wrap: wrap; }
      .detail__cta { width: 100%; flex: 1 1 100%; }
    }

    /* .cart-toast is styled globally in global.css */
  </style>
</Base>
