---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import { loadProducts } from '@lib/products';
const products = loadProducts();
const cats = ['all', ...new Set(products.map((p) => p.category))];
// Categories come from Etsy shop sections (real seller titles), shown as-is; only "all" is localized.
const catLabel: Record<string, string> = { all: 'Tümü' };
const catCount = (c: string) => (c === 'all' ? products.length : products.filter((p) => p.category === c).length);
const catImage = (c: string) => (c === 'all' ? null : products.find((p) => p.category === c)?.image ?? null);
const allImages = products.map((p) => p.image).filter(Boolean).slice(0, 4) as string[];
// Distinct crochet friends to peek in from the banner edges (one per category, spread out).
const seen = new Set<string>();
const bannerPics: string[] = [];
for (const c of cats) {
  if (c === 'all') continue;
  const img = products.find((p) => p.category === c)?.image;
  if (img && !seen.has(img)) { seen.add(img); bannerPics.push(img); }
  if (bannerPics.length >= 6) break;
}
const bPos = ['pa--l1', 'pa--r1', 'pa--l2', 'pa--r2', 'pa--l3', 'pa--r3'];
---
<Base locale="tr" title="Örgü Oyuncak & Amigurumi — El Yapımı Tüm Ürünler | Aselovers"
  description="El yapımı örgü oyuncaklar, amigurumi hayvanlar, bebek hediyeleri ve bebek odası süsleri. Yumuşak pamuk iplikle siparişe göre tek tek örülür — Türkiye ve dünyaya kargo."
  pathSelf="urunler" pathsAlt={{ tr: 'urunler', en: 'products' }}>
  <Nav locale="tr" />
  <main>
    <section class="section catalog">
      <div class="container">

        <section class="pbanner">
          <div class="pbanner__animals" aria-hidden="true">
            {bannerPics.map((src, i) => (
              <span class={`pa ${bPos[i]}`}><img class="pa__img" src={src} alt="" loading="eager" /></span>
            ))}
          </div>
          <div class="pbanner__copy">
            <p class="eyebrow">El Yapımı Koleksiyon</p>
            <h1 class="pbanner__title">Örgü Oyuncaklar & Amigurumi</h1>
            <div class="head-stitch" aria-hidden="true">
              <svg viewBox="0 0 200 8" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="7 5"><path d="M2 4 Q10 -1 20 4 T40 4 T60 4 T80 4 T100 4 T120 4 T140 4 T160 4 T180 4 T198 4"/></svg>
            </div>
            <p class="pbanner__sub">Hoş geldin! Örgü dostlarımız el sallıyor — birini seç, elde ve sevgiyle senin için örelim.</p>
          </div>
        </section>

        <div class="filterbar">
          <div class="cats" role="tablist" aria-label="Kategoriler">
            {cats.map((c) => (
              <button class="cat" role="tab" data-cat={c} aria-label={`${catLabel[c] ?? c} (${catCount(c)})`}>
                <span class="cat__img">
                  {c === 'all'
                    ? <span class="cat__collage">{allImages.map((src) => <img src={src} alt="" loading="lazy" />)}</span>
                    : (catImage(c) ? <img src={catImage(c)} alt={`${catLabel[c] ?? c} — el yapımı örgü amigurumi`} loading="lazy" /> : <span class="cat__ph" />)}
                  <span class="cat__n">{catCount(c)}</span>
                </span>
                <span class="cat__name">{catLabel[c] ?? c}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="toolbar">
          <span class="toolbar__count" id="result-count">{products.length} ürün</span>
          <div class="select-wrap">
            <select class="sort" id="sort" aria-label="Sırala">
              <option value="new">En yeni</option>
              <option value="price-asc">Fiyat: Artan</option>
              <option value="price-desc">Fiyat: Azalan</option>
            </select>
            <svg class="select-wrap__caret" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </div>
        </div>

        <div class="grid" id="grid">
          {products.map((p) => <div class="grid__item" data-cat={p.category} data-price={p.price}><ProductCard product={p} locale="tr" quickAdd /></div>)}
        </div>

        <div class="noresults" id="noresults" hidden>
          <p>Bu kategoride henüz ürün yok.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer locale="tr" />

  <style>
    /* ── Welcome banner ─────────────────────────────────────── */
    .pbanner { position: relative; overflow: hidden; border-radius: var(--radius-lg); background:
      radial-gradient(120% 140% at 50% -20%, color-mix(in srgb, var(--accent) 10%, var(--section)) 0%, var(--section) 60%);
      border: 1px solid var(--line); padding: clamp(2.4rem, 6vw, 4.2rem) clamp(1rem, 5vw, 3rem); text-align: center; margin-bottom: var(--space-6); }
    .pbanner__copy { position: relative; z-index: 2; max-width: 560px; margin: 0 auto; }
    .pbanner__title { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.4rem); margin: 0 0 var(--space-2); }
    .pbanner .head-stitch { color: color-mix(in srgb, var(--accent) 55%, var(--line)); width: 180px; max-width: 60%; margin: 0 auto var(--space-3); }
    .pbanner .head-stitch svg { display: block; width: 100%; height: 8px; }
    .pbanner__sub { color: var(--muted); margin: 0; }
    .eyebrow { justify-content: center; }

    .pbanner__animals { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
    .pa { position: absolute; width: var(--w, 108px); aspect-ratio: 1; }
    .pa__img { width: 100%; height: 100%; object-fit: cover; border-radius: 26% 26% 30% 30% / 28%; border: 4px solid var(--surface); box-shadow: 0 14px 30px rgba(28,26,24,.16); transform-origin: 50% 90%; animation: pa-sway 3.6s ease-in-out infinite; }
    .pa--l1 { top: 6%; left: -14px; --w: 122px; }
    .pa--r1 { top: 6%; right: -14px; --w: 122px; }
    .pa--l2 { top: 40%; left: 56px; --w: 88px; }
    .pa--r2 { top: 40%; right: 56px; --w: 88px; }
    .pa--l3 { bottom: -16px; left: 24px; --w: 100px; }
    .pa--r3 { bottom: -16px; right: 24px; --w: 100px; }
    /* staggered wave rhythm */
    .pa--r1 .pa__img { animation-duration: 4s; animation-delay: -.6s; }
    .pa--l2 .pa__img { animation-duration: 3.2s; animation-delay: -1.1s; }
    .pa--r2 .pa__img { animation-duration: 3.9s; animation-delay: -.3s; }
    .pa--l3 .pa__img { animation-duration: 4.3s; animation-delay: -1.6s; }
    .pa--r3 .pa__img { animation-duration: 3.5s; animation-delay: -.9s; }
    /* entrance: peek in from the monitor edges */
    .pa { animation: peek-l .9s var(--ease) both; }
    .pa[class*="--r"] { animation-name: peek-r; }
    .pa--l1 { animation-delay: .05s; } .pa--r1 { animation-delay: .12s; }
    .pa--l2 { animation-delay: .2s; }  .pa--r2 { animation-delay: .28s; }
    .pa--l3 { animation-delay: .36s; } .pa--r3 { animation-delay: .44s; }
    @keyframes peek-l { from { opacity: 0; transform: translateX(-170%) rotate(-14deg); } to { opacity: 1; transform: none; } }
    @keyframes peek-r { from { opacity: 0; transform: translateX(170%) rotate(14deg); } to { opacity: 1; transform: none; } }
    @keyframes pa-sway { 0%, 100% { transform: rotate(-6deg); } 50% { transform: rotate(6deg) translateY(-5px); } }

    @media (max-width: 1024px) { .pa--l2, .pa--r2 { display: none; } }
    @media (max-width: 700px) {
      .pa--l3, .pa--r3 { display: none; }
      .pa--l1 { --w: 74px; left: -8px; top: 10px; } .pa--r1 { --w: 74px; right: -8px; top: 10px; }
    }
    @media (prefers-reduced-motion: reduce) { .pa, .pa__img { animation: none; } }

    /* ── Header stitch (shared) ─────────────────────────────── */
    .head-stitch svg { display: block; width: 100%; height: 8px; }

    /* ── Visual category selector ───────────────────────────── */
    .filterbar { position: relative; margin-bottom: var(--space-2); }
    .cats { display: flex; gap: var(--space-5); overflow-x: auto; scrollbar-width: none; padding: var(--space-2) 2px var(--space-5); }
    .cats::-webkit-scrollbar { display: none; }
    .filterbar::after { content: ''; position: absolute; top: 0; right: 0; bottom: 22px; width: 48px; background: linear-gradient(to right, transparent, var(--bg)); pointer-events: none; }

    .cat { flex: none; width: 96px; display: flex; flex-direction: column; align-items: center; gap: 15px; background: none; border: none; padding: 0; cursor: pointer; }
    .cat__img { position: relative; width: 78px; height: 78px; }
    .cat__img > img, .cat__collage { position: absolute; inset: 0; width: 100%; height: 100%; border-radius: 50%; overflow: hidden; object-fit: cover; border: 2px solid var(--line); background: var(--section); transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
    .cat__collage { display: grid; grid-template-columns: 1fr 1fr; }
    .cat__collage img { width: 100%; height: 100%; object-fit: cover; }
    .cat__ph { position: absolute; inset: 0; border-radius: 50%; background: var(--section); border: 2px solid var(--line); }
    .cat__img::before { content: ''; position: absolute; inset: -6px; border-radius: 50%; border: 2px dashed transparent; transition: border-color var(--dur) var(--ease); pointer-events: none; }
    .cat:hover .cat__img > img, .cat:hover .cat__collage { transform: translateY(-3px); border-color: color-mix(in srgb, var(--accent) 50%, var(--line)); box-shadow: var(--shadow-hover); }
    .cat__n { position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%); z-index: 2; min-width: 22px; text-align: center; background: var(--surface); border: 1px solid var(--line); color: var(--ink); font-size: .68rem; font-weight: 700; padding: 1px 7px; border-radius: 999px; box-shadow: var(--shadow-glass); font-feature-settings: "tnum"; transition: background var(--dur) var(--ease), color var(--dur) var(--ease), border-color var(--dur) var(--ease); }
    .cat__name { font-size: .82rem; font-weight: 600; line-height: 1.2; text-align: center; max-width: 92px; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color var(--dur) var(--ease); }
    .cat:hover .cat__name { color: var(--ink); }
    .cat[aria-selected="true"] .cat__img > img, .cat[aria-selected="true"] .cat__collage { border-color: var(--accent); }
    .cat[aria-selected="true"] .cat__img::before { border-color: color-mix(in srgb, var(--accent) 55%, var(--line)); }
    .cat[aria-selected="true"] .cat__n { background: var(--accent); border-color: var(--accent); color: var(--on-accent); }
    .cat[aria-selected="true"] .cat__name { color: var(--accent-ink); }

    /* ── Toolbar + grid ─────────────────────────────────────── */
    .toolbar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); flex-wrap: wrap; margin: var(--space-4) 0 var(--space-6); }
    .toolbar__count { font-size: var(--step-small); color: var(--muted); font-feature-settings: "tnum"; }
    .select-wrap { position: relative; display: inline-flex; }
    .sort { appearance: none; -webkit-appearance: none; font: inherit; font-size: .9rem; padding: 9px 40px 9px 16px; border: 1.5px solid var(--line); border-radius: var(--radius-pill); background: var(--surface); color: var(--ink); cursor: pointer; transition: border-color var(--dur) var(--ease); }
    .sort:focus { outline: none; border-color: var(--accent); }
    .select-wrap__caret { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: var(--muted); pointer-events: none; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-6) var(--space-5); }
    .grid__item[hidden] { display: none; }
    .noresults { text-align: center; padding: var(--space-8) 0; color: var(--muted); }
  </style>

  <script>
    import { addToCart, showCartToast } from '@lib/cart';
    import type { Product } from '@lib/products';

    const params = new URLSearchParams(location.search);
    const initial = params.get('cat') || 'all';
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat'));
    const items = Array.from(document.querySelectorAll<HTMLElement>('.grid__item'));
    const countEl = document.getElementById('result-count');
    const noResults = document.getElementById('noresults');

    function apply(cat: string) {
      filters.forEach((f) => f.setAttribute('aria-selected', String(f.dataset.cat === cat)));
      let visible = 0;
      items.forEach((it) => {
        const show = cat === 'all' || it.dataset.cat === cat;
        it.hidden = !show;
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `${visible} ürün`;
      if (noResults) noResults.hidden = visible > 0;
    }
    filters.forEach((f) => f.addEventListener('click', () => apply(f.dataset.cat!)));
    apply(initial);

    const grid = document.getElementById('grid')!;
    const sortSel = document.getElementById('sort') as HTMLSelectElement | null;
    function sortItems(mode: string) {
      const nodes = Array.from(grid.querySelectorAll<HTMLElement>('.grid__item'));
      nodes.sort((a, b) => {
        const pa = parseFloat(a.dataset.price || '0'), pb = parseFloat(b.dataset.price || '0');
        if (mode === 'price-asc') return pa - pb;
        if (mode === 'price-desc') return pb - pa;
        return 0;
      });
      nodes.forEach((n) => grid.appendChild(n));
    }
    sortSel?.addEventListener('change', () => sortItems(sortSel.value));

    grid.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.card__add') as HTMLButtonElement | null;
      if (!btn) return;
      e.preventDefault();
      const id = btn.getAttribute('data-id');
      if (!id) return;
      // Varyantlı ürünler seçenek gerektirir — hızlı ekleme yanlış fiyat/seçeneksiz
      // sipariş oluşturmasın diye ürün sayfasına yönlendir.
      if (btn.getAttribute('data-opts')) {
        const href = btn.getAttribute('data-href');
        if (href) { window.location.href = href; return; }
      }
      addToCart({ id } as Product, 1);
      showCartToast({ addedLabel: 'Sepete eklendi', goLabel: 'Sepete git', cartHref: '/tr/sepet' });
    });
  </script>
</Base>
