---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { loadProducts } from '@lib/products';
import settings from '../../data/settings.json';

const allProducts = loadProducts();
const shippingCfg = (settings as any).shipping || {};
---
<Base locale="tr" title="Ödeme Yap — Aselovers" description="Fatura ve teslimat bilgilerinizi girerek ödemenizi güvenle tamamlayın." pathSelf="odeme" pathsAlt={{ tr: 'odeme', en: 'checkout' }}>
  <Nav locale="tr" />
  <main>
    <section class="section">
      <div class="container">
        <h1 class="checkout__heading">Güvenli Ödeme</h1>
        
        <div id="checkout-container" class="checkout__content">
          <!-- Col 1: Address Form / PayTR iFrame -->
          <div class="checkout__left-col">
            <!-- Delivery Info Form -->
            <form id="checkout-form" class="checkout__form">
              <h3>Teslimat ve Fatura Bilgileri</h3>
              
              <div class="form-group">
                <label for="c-name">Ad Soyad</label>
                <input type="text" id="c-name" required placeholder="Örn: Ahmet Yılmaz" />
              </div>

              <div class="form-row">
                <div class="form-group flex-1">
                  <label for="c-email">E-posta Adresi</label>
                  <input type="email" id="c-email" required placeholder="orn@mail.com" />
                </div>
                <div class="form-group flex-1">
                  <label for="c-phone">Telefon Numarası</label>
                  <input type="tel" id="c-phone" required placeholder="0555 123 45 67" />
                </div>
              </div>

              <div class="form-group">
                <label for="c-address">Açık Adres</label>
                <textarea id="c-address" required rows="3" placeholder="Mahalle, Cadde, Sokak, Kapı No, Daire"></textarea>
              </div>

              <div class="form-row">
                <div class="form-group flex-1">
                  <label for="c-city">Şehir / Eyalet</label>
                  <input type="text" id="c-city" required placeholder="Örn: İstanbul / Kadıköy" />
                </div>
                <div class="form-group flex-1">
                  <label for="c-country">Ülke / Bölge</label>
                  <select id="c-country">
                    <option value="TR" selected>Türkiye</option>
                    <option value="INTL">Yurt dışı</option>
                  </select>
                </div>
              </div>

              <div id="checkout-error" class="txt-danger" style="display: none; margin-bottom: var(--space-3);"></div>

              <button type="submit" id="checkout-submit-btn" class="btn btn--primary w-100" style="margin-top: var(--space-3);">
                Kart Ödeme Adımına Geç
              </button>
            </form>

            <!-- PayTR iFrame Container -->
            <div id="paytr-container" style="display: none;">
              <h3>Kredi Kartı ile Güvenli Ödeme</h3>
              <p class="paytr-desc">Lütfen kart bilgilerinizi girerek ödemenizi tamamlayın. Sayfayı kapatmayın.</p>
              <div id="paytr-iframe-wrapper"></div>
            </div>
          </div>

          <!-- Col 2: Cart Summary -->
          <div class="checkout__right-col">
            <div class="summary-card">
              <h3>Siparişiniz</h3>
              <div id="summary-items-list" class="summary__items-list">
                <!-- JS ile doldurulacak -->
              </div>
              <div class="summary-divider"></div>
              <div class="summary-row">
                <span>Ara Toplam</span>
                <span id="summary-subtotal">₺0,00</span>
              </div>
              <div class="summary-row">
                <span>Kargo</span>
                <span id="summary-shipping" class="txt-success">Ücretsiz</span>
              </div>
              <div class="summary-row summary-row--total">
                <span>Toplam</span>
                <span id="summary-total">₺0,00</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <div id="cart-data" data-products={JSON.stringify(allProducts)} data-shipping={JSON.stringify(shippingCfg)} style="display: none;"></div>
  <Footer locale="tr" />
</Base>

<script>
  import { getCart } from '@lib/cart';

  const allProducts = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-products') || '[]');
  const shippingCfg = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-shipping') || '{}');
  const cart = getCart();

  // Redirect if cart is empty
  if (cart.length === 0) {
    window.location.href = '/tr/sepet';
  }

  const summaryList = document.getElementById('summary-items-list');
  const subtotalEl = document.getElementById('summary-subtotal');
  const totalEl = document.getElementById('summary-total');

  // Render Summary
  let totalAmount = 0;
  let currency = 'TRY';

  cart.forEach(item => {
    const prod = allProducts.find(p => p.id === item.id);
    if (!prod) return;

    totalAmount += prod.price * item.quantity;
    currency = prod.currency;

    const formattedPrice = new Intl.NumberFormat('tr-TR', { style: 'currency', currency }).format(prod.price * item.quantity);

    const row = document.createElement('div');
    row.className = 'summary-item';
    row.innerHTML = `
      <div class="summary-item__details">
        <span class="summary-item__title">${prod.title_tr || prod.title_en} <strong>x${item.quantity}</strong></span>
      </div>
      <span class="summary-item__price">${formattedPrice}</span>
    `;
    summaryList?.appendChild(row);
  });

  const shippingEl = document.getElementById('summary-shipping');
  const countrySelect = document.getElementById('c-country') as HTMLSelectElement | null;
  const fmt = (n: number) => new Intl.NumberFormat('tr-TR', { style: 'currency', currency }).format(n);

  function calcShipping(country: string): number {
    const isTr = (country || 'TR') === 'TR';
    if (isTr) {
      const fee = Number(shippingCfg?.tr?.fee ?? 0) || 0;
      const freeOver = Number(shippingCfg?.tr?.freeOver ?? 0) || 0;
      if (freeOver > 0 && totalAmount >= freeOver) return 0;
      return fee;
    }
    return Number(shippingCfg?.intl?.fee ?? 0) || 0;
  }

  function updateTotals() {
    const shipping = calcShipping(countrySelect?.value || 'TR');
    if (subtotalEl) subtotalEl.textContent = fmt(totalAmount);
    if (shippingEl) {
      if (shipping > 0) { shippingEl.textContent = fmt(shipping); shippingEl.classList.remove('txt-success'); }
      else { shippingEl.textContent = 'Ücretsiz'; shippingEl.classList.add('txt-success'); }
    }
    if (totalEl) totalEl.textContent = fmt(totalAmount + shipping);
  }
  updateTotals();
  countrySelect?.addEventListener('change', updateTotals);

  // Form submit -> Get PayTR Token -> Load iFrame
  const form = document.getElementById('checkout-form') as HTMLFormElement | null;
  const paytrContainer = document.getElementById('paytr-container');
  const iframeWrapper = document.getElementById('paytr-iframe-wrapper');
  const errorEl = document.getElementById('checkout-error');
  const submitBtn = document.getElementById('checkout-submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Ödeme oturumu açılıyor...';
    if (errorEl) errorEl.style.display = 'none';

    const payload = {
      name: (document.getElementById('c-name') as HTMLInputElement).value,
      email: (document.getElementById('c-email') as HTMLInputElement).value,
      phone: (document.getElementById('c-phone') as HTMLInputElement).value,
      address: (document.getElementById('c-address') as HTMLTextAreaElement).value,
      city: (document.getElementById('c-city') as HTMLInputElement).value,
      country: (document.getElementById('c-country') as HTMLSelectElement).value,
      cart: cart.map(x => ({ id: x.id, quantity: x.quantity })),
      currency: currency,
      lang: 'tr'
    };

    try {
      const res = await fetch('/api/payment/paytr', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await res.json();
      if (!res.ok || data.error) {
        throw new Error(data.error || 'Ödeme oturumu oluşturulamadı.');
      }

      // Hide form, show PayTR iFrame
      form.style.display = 'none';
      if (paytrContainer) paytrContainer.style.display = 'block';

      if (iframeWrapper) {
        iframeWrapper.innerHTML = `
          <iframe src="https://www.paytr.com/odeme/guvenli/${data.token}" id="paytriframe" frameborder="0" scrolling="no" style="width: 100%; height: 650px;"></iframe>
        `;
      }
    } catch (err: any) {
      if (errorEl) {
        errorEl.textContent = err.message || 'Bir hata oluştu.';
        errorEl.style.display = 'block';
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Kart Ödeme Adımına Geç';
    }
  });
</script>

<style>
  .checkout__heading { font-family: var(--font-display); font-size: 2.2rem; font-weight: 500; margin-bottom: var(--space-6); }
  .checkout__content { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-7); align-items: start; }
  
  .checkout__form h3, #paytr-container h3 { font-family: var(--font-display); font-size: 1.4rem; margin-top: 0; margin-bottom: var(--space-4); }
  .checkout__form { background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-5); }
  
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: var(--space-4); }
  .form-group label { font-size: 0.88rem; font-weight: 600; color: var(--ink); }
  .form-group input, .form-group textarea, .form-group select { font-family: inherit; font-size: 0.95rem; padding: 10px 14px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); color: var(--ink); }
  .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: var(--accent); }
  .form-row { display: flex; gap: var(--space-4); }
  
  #paytr-container { background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-5); }
  .paytr-desc { font-size: 0.9rem; color: var(--muted); margin-bottom: var(--space-4); }
  
  .summary-card { background: #FAF9F5; border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-5); }
  .summary-card h3 { font-family: var(--font-display); font-size: 1.3rem; margin-top: 0; margin-bottom: var(--space-4); border-bottom: 1.5px solid var(--line); padding-bottom: var(--space-2); }
  
  .summary__items-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .summary-item { display: flex; justify-content: space-between; font-size: 0.92rem; }
  .summary-item__title strong { color: var(--accent); }
  .summary-item__price { font-weight: 600; color: var(--ink); }
  
  .summary-divider { height: 1px; background: var(--line); margin: var(--space-4) 0; }
  .summary-row { display: flex; justify-content: space-between; font-size: 0.95rem; margin-bottom: var(--space-3); }
  .summary-row--total { font-size: 1.15rem; font-weight: 700; color: var(--accent-ink); border-top: 1.5px solid var(--line); padding-top: var(--space-3); margin-top: var(--space-3); margin-bottom: 0; }
  
  .flex-1 { flex: 1; }
  .w-100 { width: 100%; }
  .txt-danger { color: #dc2626; font-weight: 600; }
  .txt-success { color: #16a34a; font-weight: 600; }
  
  @media (max-width: 900px) {
    .checkout__content { grid-template-columns: 1fr; }
    .form-row { flex-direction: column; gap: 0; }
  }
</style>
