---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { loadProducts } from '@lib/products';
import settings from '../../data/settings.json';

const allProducts = loadProducts();
const shippingCfg = (settings as any).shipping || {};
---
<Base locale="en" title="Checkout — Aselovers" description="Enter your shipping and billing details to securely complete your payment." pathSelf="checkout" pathsAlt={{ tr: 'odeme', en: 'checkout' }}>
  <Nav locale="en" />
  <main>
    <section class="section checkout-section">
      <div class="container">
        <div class="checkout__top">
          <a class="checkout__back" href="/en/cart">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
            Back to cart
          </a>
          <ol class="steps" aria-label="Checkout steps">
            <li class="steps__item steps__item--done"><span class="steps__n">1</span>Cart</li>
            <li class="steps__item steps__item--active" id="step-info" aria-current="step"><span class="steps__n">2</span>Details</li>
            <li class="steps__item" id="step-pay"><span class="steps__n">3</span>Payment</li>
          </ol>
        </div>

        <h1 class="checkout__heading">Secure Checkout</h1>
        <div class="head-stitch" aria-hidden="true">
          <svg viewBox="0 0 200 8" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="7 5"><path d="M2 4 Q10 -1 20 4 T40 4 T60 4 T80 4 T100 4 T120 4 T140 4 T160 4 T180 4 T198 4"/></svg>
        </div>

        <div id="checkout-container" class="checkout__content">
          <div class="checkout__left-col">
            <form id="checkout-form" class="formcard">
              <div class="formcard__head">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <h2>Shipping &amp; Billing Details</h2>
              </div>

              <div class="form-group">
                <label for="c-name">Full Name</label>
                <input type="text" id="c-name" name="name" autocomplete="name" required placeholder="e.g. John Doe" />
              </div>

              <div class="form-row">
                <div class="form-group flex-1">
                  <label for="c-email">Email Address</label>
                  <input type="email" id="c-email" name="email" autocomplete="email" inputmode="email" required placeholder="john@example.com" />
                </div>
                <div class="form-group flex-1">
                  <label for="c-phone">Phone Number</label>
                  <input type="tel" id="c-phone" name="tel" autocomplete="tel" inputmode="tel" required placeholder="+1 555 123 4567" />
                </div>
              </div>

              <!-- Country first so the address fields adapt (state / ZIP format). -->
              <div class="form-group">
                <label for="c-country">Country / Region</label>
                <div class="select-wrap">
                  <select id="c-country" name="country" autocomplete="country" required>
                    <option value="US" selected>United States</option>
                    <option value="CA">Canada</option>
                    <option value="AU">Australia</option>
                    <option value="DE">Germany</option>
                    <option value="CH">Switzerland</option>
                    <option value="INTL">Other countries</option>
                    <option value="TR">Türkiye</option>
                  </select>
                  <svg class="select-wrap__caret" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </div>
              </div>

              <div class="form-group">
                <label for="c-address">Address line 1</label>
                <input type="text" id="c-address" name="address-line1" autocomplete="address-line1" required placeholder="Street address, P.O. box, company name" />
              </div>

              <div class="form-group">
                <label for="c-address2">Address line 2 <span class="lbl-opt">(optional)</span></label>
                <input type="text" id="c-address2" name="address-line2" autocomplete="address-line2" placeholder="Apartment, suite, unit, building, floor, etc." />
              </div>

              <div class="form-row form-row--addr">
                <div class="form-group flex-1">
                  <label for="c-city">City</label>
                  <input type="text" id="c-city" name="city" autocomplete="address-level2" required placeholder="e.g. New York" />
                </div>
                <div class="form-group flex-1" id="grp-state">
                  <label for="c-state" id="lbl-state">State</label>
                  <div class="select-wrap" id="wrap-state-select">
                    <select id="c-state" name="address-level1" autocomplete="address-level1">
                      <option value="" disabled selected>Select…</option>
                    </select>
                    <svg class="select-wrap__caret" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </div>
                  <input type="text" id="c-state-text" autocomplete="address-level1" placeholder="State / Province / Region" style="display:none" />
                </div>
                <div class="form-group flex-1">
                  <label for="c-postal" id="lbl-postal">ZIP code</label>
                  <input type="text" id="c-postal" name="postal-code" autocomplete="postal-code" inputmode="numeric" required placeholder="e.g. 10001" />
                </div>
              </div>

              <div id="checkout-error" class="form-error" role="alert" style="display: none;"></div>

              <button type="submit" id="checkout-submit-btn" class="btn btn--primary checkout__submit">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Proceed to Secure Payment
              </button>

              <div class="pay-trust">
                <div class="pay-trust__row">
                  <span class="pay-trust__seal">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                    <span><b>PayTR</b> secure payment</span>
                  </span>
                  <span class="cardmarks" aria-label="Accepted cards">
                    <span class="cardmark cardmark--visa">VISA</span>
                    <span class="cardmark cardmark--mc"><i></i><i></i></span>
                    <span class="cardmark cardmark--troy">troy</span>
                  </span>
                </div>
                <ul class="pay-trust__points">
                  <li><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> 256-bit SSL encryption</li>
                  <li><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg> 3D Secure verification</li>
                  <li><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg> Your card details are never stored by us</li>
                </ul>
              </div>
            </form>

            <div id="paytr-container" class="formcard" style="display: none;">
              <div class="formcard__head">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                <h2>Secure Card Payment</h2>
              </div>
              <p class="paytr-desc">Complete your payment by entering your card details. Please do not close this page.</p>
              <div id="paytr-iframe-wrapper"></div>
            </div>
          </div>

          <aside class="checkout__right-col">
            <div class="summary-card">
              <h2 class="summary-card__h">Your Order</h2>
              <div id="summary-items-list" class="summary__items-list"></div>
              <div class="summary-divider"></div>
              <div class="summary-row">
                <span>Subtotal</span>
                <span id="summary-subtotal">$0.00</span>
              </div>
              <div class="summary-row">
                <span>Shipping</span>
                <span id="summary-shipping" class="txt-success">Free</span>
              </div>
              <div class="summary-row summary-row--total">
                <span>Total</span>
                <span id="summary-total">$0.00</span>
              </div>
            </div>

            <ul class="trust-card">
              <li><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg> Your card details are never stored by us</li>
              <li><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18.5" cy="18.5" r="2"/></svg> Tracked shipping across Türkiye &amp; worldwide</li>
              <li><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Questions? We're here on WhatsApp</li>
            </ul>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <div id="cart-data" data-products={JSON.stringify(allProducts)} data-shipping={JSON.stringify(shippingCfg)} data-rate-usd={((settings as any).rates?.usd) ?? 47.03} style="display: none;"></div>
  <Footer locale="en" />

<script>
  import { getCart } from '@lib/cart';
  import { resolveVariantPrice } from '@lib/variants';
  import { optionsLine } from '@lib/optionLabels';
  import { intlFeeNative } from '@lib/shipping';

  const allProducts = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-products') || '[]');
  const shippingCfg = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-shipping') || '{}');
  const optsText = (o?: Record<string, string>) => optionsLine(o, 'en');
  const cart = getCart();

  if (cart.length === 0) { window.location.href = '/en/cart'; }

  const summaryList = document.getElementById('summary-items-list');
  const subtotalEl = document.getElementById('summary-subtotal');
  const totalEl = document.getElementById('summary-total');

  let totalAmount = 0;
  const currency = 'USD';
  // Prices are stored in TRY; the EN checkout shows and charges USD. Convert at display.
  const usdRate = Number(document.getElementById('cart-data')?.getAttribute('data-rate-usd')) || 47.03;

  cart.forEach(item => {
    const prod = allProducts.find(p => p.id === item.id);
    if (!prod) return;
    const unit = resolveVariantPrice(prod, item.options);
    totalAmount += unit * item.quantity;
    const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format((unit * item.quantity) / usdRate);
    const img = prod.image || '/bags.png';
    const optLine = optsText(item.options);
    const row = document.createElement('div');
    row.className = 'summary-item';
    row.innerHTML = `
      <span class="summary-item__media"><img src="${img}" alt="" loading="lazy" /><span class="summary-item__qty">${item.quantity}</span></span>
      <span class="summary-item__title">${prod.title_en || prod.title_tr}${optLine ? `<span class="summary-item__opts">${optLine}</span>` : ''}</span>
      <span class="summary-item__price">${formattedPrice}</span>
    `;
    summaryList?.appendChild(row);
  });

  const shippingEl = document.getElementById('summary-shipping');
  const countrySelect = document.getElementById('c-country') as HTMLSelectElement | null;
  const fmt = (n: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n / usdRate);

  // Total units in the cart — extra items add a % of the base shipping fee.
  const itemCount = cart.reduce((s, i) => s + (Number(i.quantity) || 1), 0);

  // Returns the fee in TRY (item prices are TRY here); `fmt` converts to USD for display,
  // mirroring the server so the amount shown equals the amount charged.
  function calcShipping(country: string): number {
    const isTr = (country || 'TR') === 'TR';
    if (isTr) {
      const fee = Number(shippingCfg?.tr?.fee ?? 0) || 0;
      const freeOver = Number(shippingCfg?.tr?.freeOver ?? 0) || 0;
      if (freeOver > 0 && totalAmount >= freeOver) return 0;
      return fee;
    }
    return intlFeeNative(shippingCfg, country, itemCount) * usdRate;
  }

  function updateTotals() {
    const shipping = calcShipping(countrySelect?.value || 'TR');
    if (subtotalEl) subtotalEl.textContent = fmt(totalAmount);
    if (shippingEl) {
      if (shipping > 0) { shippingEl.textContent = fmt(shipping); shippingEl.classList.remove('txt-success'); }
      else { shippingEl.textContent = 'Free'; shippingEl.classList.add('txt-success'); }
    }
    if (totalEl) totalEl.textContent = fmt(totalAmount + shipping);
  }
  updateTotals();
  countrySelect?.addEventListener('change', updateTotals);

  // ── Country-aware address fields (state picker + ZIP/postal format) ──────
  const US_STATES: [string, string][] = [
    ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
    ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['DC','District of Columbia'],
    ['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],
    ['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],['KY','Kentucky'],['LA','Louisiana'],
    ['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],
    ['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],
    ['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],['NY','New York'],
    ['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],['OR','Oregon'],
    ['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
    ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],
    ['WA','Washington'],['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming'],
  ];
  type Rule = { state: 'select' | 'text' | 'hide'; stateLabel?: string; stateReq?: boolean;
    postalLabel: string; postalRe?: RegExp | null; postalReq?: boolean; postalPh?: string };
  const RULES: Record<string, Rule> = {
    US: { state: 'select', stateLabel: 'State', stateReq: true, postalLabel: 'ZIP code', postalRe: /^\d{5}(-\d{4})?$/, postalReq: true, postalPh: 'e.g. 10001' },
    CA: { state: 'text', stateLabel: 'Province', stateReq: true, postalLabel: 'Postal code', postalRe: /^[A-Za-z]\d[A-Za-z][ -]?\d[A-Za-z]\d$/, postalReq: true, postalPh: 'e.g. K1A 0B1' },
    AU: { state: 'text', stateLabel: 'State / Territory', stateReq: true, postalLabel: 'Postcode', postalRe: /^\d{4}$/, postalReq: true, postalPh: 'e.g. 2000' },
    DE: { state: 'hide', postalLabel: 'Postal code', postalRe: /^\d{5}$/, postalReq: true, postalPh: 'e.g. 10115' },
    CH: { state: 'hide', postalLabel: 'Postal code', postalRe: /^\d{4}$/, postalReq: true, postalPh: 'e.g. 8001' },
    INTL: { state: 'text', stateLabel: 'State / Region', stateReq: false, postalLabel: 'Postal code', postalRe: null, postalReq: true, postalPh: 'Postal / ZIP code' },
    TR: { state: 'text', stateLabel: 'Province', stateReq: false, postalLabel: 'Postal code', postalRe: null, postalReq: false, postalPh: 'Optional' },
  };
  const stateSel = document.getElementById('c-state') as HTMLSelectElement | null;
  const stateTxt = document.getElementById('c-state-text') as HTMLInputElement | null;
  const stateWrap = document.getElementById('wrap-state-select');
  const stateGrp = document.getElementById('grp-state');
  const stateLbl = document.getElementById('lbl-state');
  const postalEl = document.getElementById('c-postal') as HTMLInputElement | null;
  const postalLbl = document.getElementById('lbl-postal');
  if (stateSel) US_STATES.forEach(([v, n]) => { const o = document.createElement('option'); o.value = v; o.textContent = n; stateSel.appendChild(o); });

  const rule = () => RULES[countrySelect?.value || 'US'] || RULES.INTL;
  const stateValue = () => {
    const r = rule();
    if (r.state === 'hide') return '';
    return (r.state === 'select' ? stateSel?.value : stateTxt?.value)?.trim() || '';
  };
  function applyCountry() {
    const r = rule();
    if (stateGrp) stateGrp.style.display = r.state === 'hide' ? 'none' : '';
    if (r.state !== 'hide' && stateLbl) stateLbl.textContent = r.stateLabel || 'State / Region';
    if (stateWrap) stateWrap.style.display = r.state === 'select' ? '' : 'none';
    if (stateTxt) { stateTxt.style.display = r.state === 'text' ? '' : 'none'; stateTxt.placeholder = r.stateLabel || 'State / Province / Region'; }
    if (postalLbl) postalLbl.textContent = r.postalLabel;
    if (postalEl) { postalEl.placeholder = r.postalPh || ''; postalEl.inputMode = r.postalRe && r.postalRe.source.startsWith('^\\d') ? 'numeric' : 'text'; }
  }
  countrySelect?.addEventListener('change', () => { applyCountry(); clearErr(stateSel); clearErr(stateTxt); clearErr(postalEl); });
  applyCountry();

  const form = document.getElementById('checkout-form') as HTMLFormElement | null;
  const paytrContainer = document.getElementById('paytr-container');
  const iframeWrapper = document.getElementById('paytr-iframe-wrapper');
  const errorEl = document.getElementById('checkout-error');
  const submitBtn = document.getElementById('checkout-submit-btn') as HTMLButtonElement | null;

  // ── Validation — required fields checked so no incomplete/garbage order ──
  const val = (id: string) => ((document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null)?.value || '').trim();
  function fieldGroup(el: HTMLElement) { return el.closest('.form-group'); }
  function setErr(el: HTMLElement, msg: string) {
    el.classList.add('is-invalid');
    const g = fieldGroup(el); if (!g) return;
    let s = g.querySelector('.fielderr') as HTMLElement | null;
    if (!s) { s = document.createElement('span'); s.className = 'fielderr'; g.appendChild(s); }
    s.textContent = msg;
  }
  function clearErr(el: HTMLElement | null) {
    if (!el) return;
    el.classList.remove('is-invalid');
    const s = fieldGroup(el)?.querySelector('.fielderr') as HTMLElement | null;
    if (s) s.textContent = '';
  }
  function validate(): boolean {
    let ok = true; let firstBad: HTMLElement | null = null;
    const fail = (id: string, msg: string) => { const el = document.getElementById(id); if (el) { setErr(el, msg); if (!firstBad) firstBad = el; } ok = false; };
    const failEl = (el: HTMLElement | null, msg: string) => { if (el) { setErr(el, msg); if (!firstBad) firstBad = el; } ok = false; };
    const pass = (id: string) => clearErr(document.getElementById(id));
    const r = rule();
    const nameV = val('c-name');
    if (nameV.length < 3 || !/\s/.test(nameV)) fail('c-name', 'Please enter your full name.'); else pass('c-name');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(val('c-email'))) fail('c-email', 'Enter a valid email address.'); else pass('c-email');
    if (val('c-phone').replace(/[^0-9]/g, '').length < 7) fail('c-phone', 'Enter a valid phone number.'); else pass('c-phone');
    if (val('c-address').length < 5) fail('c-address', 'Enter your street address.'); else pass('c-address');
    if (val('c-city').length < 2) fail('c-city', 'Enter your city.'); else pass('c-city');
    // State / province — required where the destination country uses one.
    if (r.state !== 'hide' && r.stateReq) {
      const stEl = r.state === 'select' ? stateSel : stateTxt;
      if (!stateValue()) failEl(stEl, (r.state === 'select' ? 'Select your ' : 'Enter your ') + (r.stateLabel || 'state').toLowerCase() + '.');
      else { clearErr(stateSel); clearErr(stateTxt); }
    } else { clearErr(stateSel); clearErr(stateTxt); }
    // ZIP / postal code — required and format-checked per country.
    const zip = val('c-postal');
    if (r.postalReq && !zip) fail('c-postal', 'Enter your ' + r.postalLabel.toLowerCase() + '.');
    else if (zip && r.postalRe && !r.postalRe.test(zip)) fail('c-postal', 'Enter a valid ' + r.postalLabel.toLowerCase() + '.');
    else pass('c-postal');
    if (firstBad) { (firstBad as HTMLElement).focus({ preventScroll: true }); (firstBad as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    return ok;
  }
  ['c-name', 'c-email', 'c-phone', 'c-address', 'c-address2', 'c-city', 'c-state-text', 'c-postal'].forEach((id) => {
    document.getElementById(id)?.addEventListener('input', function (this: HTMLElement) { clearErr(this); });
  });
  stateSel?.addEventListener('change', function (this: HTMLElement) { clearErr(this); });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;
    if (!validate()) return;
    submitBtn.disabled = true;
    submitBtn.classList.add('is-loading');
    submitBtn.textContent = 'Opening payment session…';
    if (errorEl) errorEl.style.display = 'none';

    const line1 = (document.getElementById('c-address') as HTMLInputElement).value.trim();
    const line2 = (document.getElementById('c-address2') as HTMLInputElement).value.trim();
    const payload = {
      name: (document.getElementById('c-name') as HTMLInputElement).value,
      email: (document.getElementById('c-email') as HTMLInputElement).value,
      phone: (document.getElementById('c-phone') as HTMLInputElement).value,
      address: line2 ? `${line1}, ${line2}` : line1,
      city: (document.getElementById('c-city') as HTMLInputElement).value,
      province: stateValue(),
      postal: (document.getElementById('c-postal') as HTMLInputElement).value,
      country: countrySelect?.value || 'US',
      cart: cart.map(x => ({ id: x.id, quantity: x.quantity, options: x.options })),
      currency: currency,
      lang: 'en'
    };

    try {
      const res = await fetch('/api/payment/paytr', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok || data.error) { throw new Error(data.error || 'Could not create payment session.'); }

      form.style.display = 'none';
      if (paytrContainer) paytrContainer.style.display = 'block';
      document.getElementById('checkout-container')?.classList.add('is-paying');
      document.getElementById('step-info')?.classList.remove('steps__item--active');
      document.getElementById('step-info')?.classList.add('steps__item--done');
      document.getElementById('step-pay')?.classList.add('steps__item--active');
      if (iframeWrapper) {
        // Two mobile fixes in the inline style:
        //  • width:1px + min-width:100% stops iOS from sizing the iframe to its
        //    CONTENT width — that was the sideways scroll.
        //  • a tall initial height means that even if PayTR's auto-resizer never
        //    fires, the whole form (incl. the pay button) is reachable by normal
        //    page scroll — no nested/erratic scrollbar. If the resizer DOES fire
        //    it shrinks this to the exact content height (no blank space).
        iframeWrapper.innerHTML = `<iframe src="https://www.paytr.com/odeme/guvenli/${data.token}" id="paytriframe" frameborder="0" scrolling="no" style="width:1px;min-width:100%;height:1300px;border:0;"></iframe>`;
        const runResize = () => { try { ((window as any).iFrameResize || (window as any).iframeResize)?.({ checkOrigin: false, heightCalculationMethod: 'lowestElement' }, '#paytriframe'); } catch (e) {} };
        const startResize = () => {
          runResize();
          // PayTR's form grows as it loads (card type → installments → agreement);
          // re-run so the height keeps up and the pay button is always reachable.
          document.getElementById('paytriframe')?.addEventListener('load', runResize);
          setTimeout(runResize, 1200);
          setTimeout(runResize, 3000);
        };
        if ((window as any).iFrameResize) { startResize(); }
        else {
          const s = document.createElement('script');
          s.src = 'https://www.paytr.com/js/iframeResizer.min.js';
          s.onload = startResize;
          document.body.appendChild(s);
        }
      }
      paytrContainer?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err: any) {
      if (errorEl) { errorEl.textContent = err.message || 'An error occurred.'; errorEl.style.display = 'flex'; }
      submitBtn.disabled = false;
      submitBtn.classList.remove('is-loading');
      submitBtn.textContent = 'Proceed to Secure Payment';
    }
  });
</script>

  <style>
    .checkout-section { padding-top: var(--space-6); }
    .checkout__top { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-5); }
    .checkout__back { display: inline-flex; align-items: center; gap: 6px; font-size: var(--step-small); font-weight: 600; color: var(--muted); transition: color var(--dur) var(--ease); }
    .checkout__back:hover { color: var(--accent); }

    .steps { list-style: none; display: flex; align-items: center; gap: var(--space-3); margin: 0; padding: 0; }
    .steps__item { display: inline-flex; align-items: center; gap: 8px; font-size: var(--step-small); font-weight: 600; color: var(--muted); }
    .steps__item:not(:last-child)::after { content: ''; width: 26px; border-top: 2px dashed var(--line); margin-left: var(--space-3); }
    .steps__item--done::after { border-color: color-mix(in srgb, var(--accent) 50%, var(--line)); }
    .steps__n { display: grid; place-items: center; width: 24px; height: 24px; border-radius: 50%; border: 1.5px solid var(--line); font-size: .8rem; background: var(--surface); }
    .steps__item--active { color: var(--accent-ink); }
    .steps__item--active .steps__n { border-color: var(--accent); background: var(--accent); color: var(--on-accent); }
    .steps__item--done { color: var(--ink); }
    .steps__item--done .steps__n { border-color: var(--accent); color: var(--accent); }

    .checkout__heading { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem); margin-bottom: var(--space-2); }
    .head-stitch { color: color-mix(in srgb, var(--accent) 55%, var(--line)); width: 190px; max-width: 55%; margin: 0 0 var(--space-6); }
    .head-stitch svg { display: block; width: 100%; height: 8px; }
    @media (max-width: 420px) { .steps__item:not(:last-child)::after { display: none; } .steps { gap: var(--space-2); } }
    .checkout__content { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-6); align-items: start; }

    .formcard { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-glass); }
    .formcard__head { display: flex; align-items: center; gap: 10px; margin-bottom: var(--space-5); padding-bottom: var(--space-4); border-bottom: 1px solid var(--line); color: var(--accent); }
    .formcard__head h2 { font-family: var(--font-display); font-size: 1.35rem; margin: 0; color: var(--ink); }

    .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: var(--space-4); }
    .form-group label { font-size: .84rem; font-weight: 600; color: var(--ink); }
    .form-group input, .form-group textarea, .form-group select {
      font-family: inherit; font-size: 0.95rem; min-height: 48px; padding: 12px 14px;
      border: 1.5px solid var(--line); border-radius: 12px; background: var(--bg); color: var(--ink);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), background var(--dur) var(--ease);
    }
    .form-group textarea { min-height: 84px; resize: vertical; line-height: 1.6; }
    .form-group input::placeholder, .form-group textarea::placeholder { color: color-mix(in srgb, var(--muted) 65%, transparent); }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      outline: none; border-color: var(--accent); background: var(--surface);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent);
    }
    .form-row { display: flex; gap: var(--space-4); }
    .lbl-opt { font-weight: 400; color: color-mix(in srgb, var(--muted) 80%, transparent); font-size: .85em; }

    .select-wrap { position: relative; display: flex; }
    .select-wrap select { width: 100%; appearance: none; -webkit-appearance: none; padding-right: 40px; cursor: pointer; }
    .select-wrap__caret { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--muted); pointer-events: none; }

    .form-error { display: flex; align-items: center; gap: 8px; background: color-mix(in srgb, #dc2626 8%, var(--surface)); border: 1px solid color-mix(in srgb, #dc2626 30%, var(--line)); color: #b91c1c; font-size: .9rem; font-weight: 500; padding: 10px 14px; border-radius: 10px; margin-bottom: var(--space-4); }

    .checkout__submit { width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 10px; height: 54px; margin-top: var(--space-2); border-radius: var(--radius-pill); font-size: 1rem; font-weight: 600; }
    .checkout__submit.is-loading { opacity: .75; cursor: progress; }
    .secure-note { display: flex; align-items: center; justify-content: center; gap: 7px; text-align: center; font-size: .8rem; color: var(--muted); margin: var(--space-3) 0 0; }
    .secure-note svg { color: var(--accent); flex-shrink: 0; }

    /* Inline field validation */
    .fielderr { display: block; color: #dc2626; font-size: .78rem; margin-top: 5px; font-weight: 500; }
    .form-group input.is-invalid, .form-group textarea.is-invalid, .form-group select.is-invalid {
      border-color: #dc2626; box-shadow: 0 0 0 3px color-mix(in srgb, #dc2626 14%, transparent);
    }

    /* Payment-security / trust bar */
    .pay-trust { margin-top: var(--space-4); padding: var(--space-4); border: 1px solid var(--line); border-radius: 14px; background: color-mix(in srgb, var(--accent) 4%, var(--surface)); }
    .pay-trust__row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); flex-wrap: wrap; }
    .pay-trust__seal { display: inline-flex; align-items: center; gap: 8px; font-size: .92rem; color: var(--ink); }
    .pay-trust__seal svg { color: #16a34a; flex-shrink: 0; }
    .pay-trust__seal b { color: var(--accent-ink); font-weight: 800; }
    .cardmarks { display: inline-flex; align-items: center; gap: 7px; }
    .cardmark { height: 26px; min-width: 42px; padding: 0 8px; display: inline-flex; align-items: center; justify-content: center; border-radius: 5px; background: #fff; border: 1px solid var(--line); font-size: .72rem; font-weight: 800; }
    .cardmark--visa { color: #1a1f71; font-style: italic; letter-spacing: .04em; }
    .cardmark--troy { color: #00a1a1; font-style: italic; }
    .cardmark--mc { padding: 0 10px; }
    .cardmark--mc i { width: 15px; height: 15px; border-radius: 50%; display: block; }
    .cardmark--mc i:first-child { background: #eb001b; }
    .cardmark--mc i:last-child { background: #f79e1b; margin-left: -7px; mix-blend-mode: multiply; }
    .pay-trust__points { list-style: none; margin: var(--space-3) 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 6px 16px; }
    .pay-trust__points li { display: inline-flex; align-items: center; gap: 6px; font-size: .8rem; color: var(--muted); }
    .pay-trust__points svg { color: #16a34a; flex-shrink: 0; }

    .paytr-desc { font-size: 0.9rem; color: var(--muted); margin-bottom: var(--space-4); }
    /* Grid/flex children default to min-width:auto and refuse to shrink below
       their content — the wide PayTR iframe then overflows and the whole page
       shifts sideways on mobile. min-width:0 lets the column shrink. */
    .checkout__left-col, .checkout__right-col { min-width: 0; }
    #paytr-iframe-wrapper { border-radius: 12px; max-width: 100%; overflow: hidden; }
    /* width:1px + min-width:100% stops iOS from blowing the iframe out to its
       content width — the real cause of the sideways scroll on phones. */
    #paytr-iframe-wrapper iframe { display: block; width: 1px; min-width: 100%; max-width: 100%; border: 0; }

    .summary-card { background: var(--section); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-5); position: sticky; top: 96px; }
    .summary-card__h { font-family: var(--font-display); font-size: 1.3rem; margin: 0 0 var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); }
    .summary__items-list { display: flex; flex-direction: column; gap: var(--space-4); }
    /* Summary rows are injected via innerHTML, so their styles MUST be global
       (Astro's scoped styles never reach dynamically-created DOM). */
    :global(.summary-item) { display: grid; grid-template-columns: 48px 1fr auto; align-items: center; gap: var(--space-3); font-size: .9rem; }
    :global(.summary-item__media) { position: relative; width: 48px; height: 48px; flex-shrink: 0; }
    :global(.summary-item__media img) { width: 48px; height: 48px; object-fit: cover; border-radius: 10px; border: 1px solid var(--line); background: var(--surface); }
    :global(.summary-item__qty) { position: absolute; top: -7px; right: -7px; min-width: 20px; height: 20px; padding: 0 5px; display: grid; place-items: center; background: var(--accent); color: var(--on-accent); font-size: .72rem; font-weight: 700; border-radius: 10px; border: 2px solid var(--section); }
    :global(.summary-item__title) { line-height: 1.35; color: var(--ink); }
    :global(.summary-item__opts) { display: block; font-size: .8rem; color: var(--accent-ink); font-weight: 600; margin-top: 2px; }
    :global(.summary-item__price) { font-weight: 600; color: var(--ink); font-feature-settings: "tnum"; white-space: nowrap; }

    .summary-divider { height: 1px; background: var(--line); margin: var(--space-4) 0; }
    .summary-row { display: flex; justify-content: space-between; font-size: 0.95rem; margin-bottom: var(--space-3); color: var(--muted); }
    .summary-row span:last-child { color: var(--ink); font-feature-settings: "tnum"; }
    .summary-row--total { font-size: 1.2rem; font-weight: 700; color: var(--accent-ink); border-top: 1px solid var(--line); padding-top: var(--space-3); margin-top: var(--space-3); margin-bottom: 0; }
    .summary-row--total span:last-child { color: var(--accent-ink); }

    .trust-card { list-style: none; margin: var(--space-4) 0 0; padding: 0; display: grid; gap: var(--space-3); }
    .trust-card li { display: flex; align-items: center; gap: 10px; font-size: .84rem; color: var(--muted); }
    .trust-card svg { color: var(--accent); flex-shrink: 0; }

    .flex-1 { flex: 1; min-width: 0; }
    .txt-success { color: #16a34a; font-weight: 600; }

    @media (max-width: 900px) {
      .checkout__content { grid-template-columns: 1fr; }
      .summary-card { position: static; order: -1; }
      .form-row { flex-direction: column; gap: 0; }
      .formcard { padding: var(--space-5); }
      /* On the payment step, drop the summary/trust column so the phone lands
         straight on the card form — no scrolling past it to reach the fields. */
      .checkout__content.is-paying .checkout__right-col { display: none; }
      /* Give the PayTR iframe the full card width on phones. */
      #paytr-container { padding: var(--space-2); }
    }
  </style>
