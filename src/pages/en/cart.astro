---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { loadProducts } from '@lib/products';
import settings from '../../data/settings.json';

const allProducts = loadProducts();
const shippingCfg = (settings as any).shipping || {};
---
<Base locale="en" title="Shopping Cart — Aselovers" description="Check the items in your shopping cart and proceed to checkout." pathSelf="cart" pathsAlt={{ tr: 'sepet', en: 'cart' }}>
  <Nav locale="en" />
  <main>
    <section class="section cart-section">
      <div class="container">
        <h1 class="cart__heading">Shopping Cart</h1>
        <div class="head-stitch" aria-hidden="true">
          <svg viewBox="0 0 200 8" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="7 5"><path d="M2 4 Q10 -1 20 4 T40 4 T60 4 T80 4 T100 4 T120 4 T140 4 T160 4 T180 4 T198 4"/></svg>
        </div>

        <div id="cart-empty" class="cart__empty" style="display: none;">
          <span class="cart__empty-ic">
            <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </span>
          <h2 class="cart__empty-h">Your cart is empty</h2>
          <p>Browse our little handmade friends — your favorite is just a click away.</p>
          <a class="btn btn--primary" href="/en/products">Start Shopping</a>
        </div>

        <div id="cart-content" class="cart__content" style="display: none;">
          <div class="cart__items-col">
            <div class="cart__table-header">
              <span>Product</span>
              <span class="txt-center">Quantity</span>
              <span class="txt-right">Total</span>
            </div>
            <div id="cart-items-list" class="cart__items-list"></div>
            <a class="cart__continue" href="/en/products">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
              Continue shopping
            </a>
          </div>

          <aside class="cart__summary-col">
            <div class="summary-card">
              <h2 class="summary-card__h">Order Summary</h2>
              <div class="summary-row">
                <span>Subtotal</span>
                <span id="cart-subtotal">$0.00</span>
              </div>
              <div class="summary-row">
                <span>Shipping</span>
                <span id="cart-shipping">Calculated at checkout</span>
              </div>
              <div class="stitch" aria-hidden="true">
                <svg viewBox="0 0 240 8" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="7 5"><path d="M2 4 Q10 -1 20 4 T40 4 T60 4 T80 4 T100 4 T120 4 T140 4 T160 4 T180 4 T200 4 T220 4 T238 4"/></svg>
              </div>
              <div class="summary-row summary-row--total">
                <span>Total</span>
                <span id="cart-total">$0.00</span>
              </div>
              <a href="/en/checkout" class="btn btn--primary cart__checkout">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Proceed to Checkout
              </a>
              <p class="cart__secure">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                Secure payment · Your card details are never stored by us
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <div id="cart-data" data-products={JSON.stringify(allProducts)} data-shipping={JSON.stringify(shippingCfg)} data-rate-usd={((settings as any).rates?.usd) ?? 47.03} style="display: none;"></div>
  <Footer locale="en" />
</Base>

<script>
  import { getCart, updateCartQuantity, removeFromCart } from '@lib/cart';
  import { resolveVariantPrice } from '@lib/variants';
  import { optionsLine } from '@lib/optionLabels';

  const allProducts = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-products') || '[]');
  const shippingCfg = JSON.parse(document.getElementById('cart-data')?.getAttribute('data-shipping') || '{}');
  // Prices are stored in TRY; the EN site shows USD. Convert at format time.
  const usdRate = Number(document.getElementById('cart-data')?.getAttribute('data-rate-usd')) || 47.03;
  const optsText = (o?: Record<string, string>) => optionsLine(o, 'en');
  const esc = (s: string) => String(s ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

  const emptyDiv = document.getElementById('cart-empty');
  const contentDiv = document.getElementById('cart-content');
  const itemsList = document.getElementById('cart-items-list');
  const subtotalEl = document.getElementById('cart-subtotal');
  const shippingEl = document.getElementById('cart-shipping');
  const totalEl = document.getElementById('cart-total');

  function renderCart() {
    const cart = getCart();
    if (cart.length === 0) {
      if (emptyDiv) emptyDiv.style.display = 'block';
      if (contentDiv) contentDiv.style.display = 'none';
      return;
    }
    if (emptyDiv) emptyDiv.style.display = 'none';
    if (contentDiv) contentDiv.style.display = 'grid';
    if (itemsList) itemsList.innerHTML = '';

    let subtotal = 0;
    const fmt = (n: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n / usdRate);

    cart.forEach((item, idx) => {
      const prod = allProducts.find(p => p.id === item.id);
      if (!prod) return;
      const unit = resolveVariantPrice(prod, item.options);
      subtotal += unit * item.quantity;
      const optLine = optsText(item.options);

      const row = document.createElement('div');
      row.className = 'citem';
      row.innerHTML = `
        <div class="citem__product">
          <div class="citem__media"><img src="${prod.image || '/bags.png'}" alt="${esc(prod.title_en || prod.title_tr)}" loading="lazy" /></div>
          <div class="citem__info">
            <h3 class="citem__title">${esc(prod.title_en || prod.title_tr)}</h3>
            ${optLine ? `<span class="citem__opts">${esc(optLine)}</span>` : ''}
            <span class="citem__unit">${fmt(unit)}</span>
            <button class="citem__remove" data-idx="${idx}">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
              Remove
            </button>
          </div>
        </div>
        <div class="citem__qty">
          <div class="cstep" role="group" aria-label="Quantity">
            <button class="cstep__btn cstep__minus" data-idx="${idx}" aria-label="Decrease">−</button>
            <span class="cstep__val">${item.quantity}</span>
            <button class="cstep__btn cstep__plus" data-idx="${idx}" aria-label="Increase">+</button>
          </div>
        </div>
        <div class="citem__total">${fmt(unit * item.quantity)}</div>
      `;
      itemsList?.appendChild(row);
    });

    if (subtotalEl) subtotalEl.textContent = fmt(subtotal);
    // Destination (and its per-country rate) is chosen on the next step, so the cart
    // never guesses a fee — showing the TR domestic rate to an international buyer
    // would be wrong. Shipping is added on the checkout page.
    if (shippingEl) { shippingEl.textContent = 'Calculated at checkout'; shippingEl.classList.remove('txt-success'); }
    if (totalEl) totalEl.textContent = fmt(subtotal);

    document.querySelectorAll('.cstep__minus').forEach(btn => btn.addEventListener('click', () => {
      const it = getCart()[Number(btn.getAttribute('data-idx'))];
      if (it && it.quantity > 1) { updateCartQuantity(it.id, it.quantity - 1, it.options); renderCart(); }
    }));
    document.querySelectorAll('.cstep__plus').forEach(btn => btn.addEventListener('click', () => {
      const it = getCart()[Number(btn.getAttribute('data-idx'))];
      if (it) { updateCartQuantity(it.id, it.quantity + 1, it.options); renderCart(); }
    }));
    document.querySelectorAll('.citem__remove').forEach(btn => btn.addEventListener('click', () => {
      const it = getCart()[Number(btn.getAttribute('data-idx'))];
      if (it) { removeFromCart(it.id, it.options); renderCart(); }
    }));
  }

  renderCart();
  window.addEventListener('cart-updated', renderCart);
</script>

<style>
  .cart-section { padding-top: var(--space-6); }
  .cart__heading { font-family: var(--font-display); font-size: clamp(1.9rem, 3vw, 2.4rem); margin-bottom: var(--space-2); }
  .head-stitch { color: color-mix(in srgb, var(--accent) 55%, var(--line)); width: 190px; max-width: 55%; margin: 0 0 var(--space-6); }
  .head-stitch svg { display: block; width: 100%; height: 8px; }

  .cart__empty { text-align: center; max-width: 420px; margin: 0 auto; padding: var(--space-8) 0; }
  .cart__empty-ic { display: inline-grid; place-items: center; width: 76px; height: 76px; border-radius: 50%; background: var(--section); color: var(--accent); margin-bottom: var(--space-4); }
  .cart__empty-h { font-family: var(--font-display); font-size: 1.5rem; margin-bottom: var(--space-2); }
  .cart__empty p { color: var(--muted); margin-bottom: var(--space-5); }

  .cart__content { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--space-6); align-items: start; }
  .cart__table-header { display: grid; grid-template-columns: 1fr 150px 120px; padding-bottom: var(--space-3); border-bottom: 1.5px dashed color-mix(in srgb, var(--accent) 30%, var(--line)); font-weight: 600; color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; }
  .cart__table-header .txt-center { text-align: center; }
  .cart__table-header .txt-right { text-align: right; }
  .cart__items-list { display: flex; flex-direction: column; }

  .cart__continue { display: inline-flex; align-items: center; gap: 6px; margin-top: var(--space-5); font-size: .9rem; font-weight: 600; color: var(--muted); transition: color var(--dur) var(--ease); }
  .cart__continue:hover { color: var(--accent); }

  /* Cart items are injected via innerHTML at runtime, so their styles MUST be global
     (Astro's scoped styles never reach dynamically-created DOM). */
  :global(.citem) { display: grid; grid-template-columns: 1fr 150px 120px; align-items: center; gap: var(--space-3); padding: var(--space-4) 0; border-bottom: 1px solid var(--line); }
  :global(.citem__product) { display: flex; gap: var(--space-4); align-items: center; min-width: 0; }
  :global(.citem__media) { flex-shrink: 0; width: 76px; height: 76px; border-radius: var(--radius); overflow: hidden; background: var(--section); border: 1px solid var(--line); }
  :global(.citem__media img) { width: 100%; height: 100%; object-fit: cover; }
  :global(.citem__info) { min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  :global(.citem__title) { font-family: var(--font-body); font-size: .96rem; font-weight: 600; margin: 0; line-height: 1.35; color: var(--ink); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  :global(.citem__opts) { font-size: .8rem; color: var(--accent-ink); font-weight: 600; }
  :global(.citem__unit) { font-size: .85rem; color: var(--muted); }
  :global(.citem__remove) { display: inline-flex; align-items: center; gap: 5px; align-self: flex-start; background: none; border: none; color: var(--muted); cursor: pointer; font-size: .8rem; font-weight: 500; padding: 2px 0; margin-top: 2px; transition: color var(--dur) var(--ease); }
  :global(.citem__remove:hover) { color: var(--accent); }
  :global(.citem__remove svg) { pointer-events: none; }

  :global(.citem__qty) { display: flex; justify-content: center; }
  :global(.cstep) { display: inline-flex; align-items: center; border: 1.5px solid var(--line); border-radius: var(--radius-pill); background: var(--surface); overflow: hidden; }
  :global(.cstep__btn) { width: 38px; height: 42px; border: none; background: none; font-size: 1.15rem; color: var(--ink); cursor: pointer; transition: background var(--dur) var(--ease), color var(--dur) var(--ease); }
  :global(.cstep__btn:hover) { background: var(--section); color: var(--accent); }
  :global(.cstep__val) { min-width: 30px; text-align: center; font-weight: 600; font-feature-settings: "tnum"; }
  :global(.citem__total) { text-align: right; font-weight: 700; color: var(--accent-ink); font-feature-settings: "tnum"; }

  .stitch { color: color-mix(in srgb, var(--accent) 55%, var(--line)); margin: var(--space-4) 0; }
  .stitch svg { display: block; width: 100%; height: 8px; }

  .summary-card { background: var(--section); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-5); position: sticky; top: 96px; }
  .summary-card__h { font-family: var(--font-display); font-size: 1.3rem; margin: 0 0 var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); }
  .summary-row { display: flex; justify-content: space-between; font-size: .95rem; margin-bottom: var(--space-3); color: var(--muted); }
  .summary-row span:last-child { color: var(--ink); font-feature-settings: "tnum"; }
  .summary-row--total { font-size: 1.2rem; font-weight: 700; color: var(--accent-ink); margin-bottom: 0; }
  .summary-row--total span:last-child { color: var(--accent-ink); }

  .cart__checkout { width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 10px; height: 52px; margin-top: var(--space-4); font-size: 1rem; font-weight: 600; }
  .cart__secure { display: flex; align-items: center; justify-content: center; gap: 7px; text-align: center; font-size: .78rem; color: var(--muted); margin: var(--space-3) 0 0; }
  .cart__secure svg { color: var(--accent); flex-shrink: 0; }

  .txt-success { color: #16a34a; font-weight: 600; }

  @media (max-width: 900px) {
    .cart__content { grid-template-columns: 1fr; }
    .summary-card { position: static; }
    .cart__table-header { display: none; }
    :global(.citem) { grid-template-columns: 1fr auto; grid-template-areas: "product total" "qty qty"; row-gap: var(--space-3); }
    :global(.citem__product) { grid-area: product; }
    :global(.citem__total) { grid-area: total; align-self: start; }
    :global(.citem__qty) { grid-area: qty; justify-content: flex-start; }
  }
  @media (max-width: 420px) {
    :global(.citem__media) { width: 64px; height: 64px; }
  }
</style>
