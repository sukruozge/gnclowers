---
import type { Locale } from '@lib/i18n';
import { t } from '@lib/i18n';

interface Props { locale: Locale }
const { locale } = Astro.props as Props;
const isTr = locale === 'tr';

const wa = `https://wa.me/905067927685?text=${encodeURIComponent(t('wa.msg', locale))}`;
const etsy = 'https://www.etsy.com/shop/aselovers';

const L = isTr
  ? {
      eyebrow: 'merhaba de',
      title: 'Bir ilmek atalım mı?',
      story:
        'Sorularınız, özel siparişleriniz ve iş birlikleri için buradayız. WhatsApp’tan yazın, Etsy mağazamıza göz atın — her sipariş sizin için tek tek, sevgiyle elde örülür.',
      tag: 'genelde birkaç saat içinde yanıtlıyoruz',
    }
  : {
      eyebrow: 'say hello',
      title: 'Shall we cast on a stitch?',
      story:
        'We’re here for your questions, custom orders, and collaborations. Message us on WhatsApp or browse our Etsy shop — every order is crocheted by hand, with love, just for you.',
      tag: 'we usually reply within a few hours',
    };

const titleWords = L.title.split(' ');
---
<section class="chero">
  <img class="chero__mascot" src="/images/contact-bunny.png" alt="" width="1024" height="1024" fetchpriority="high" />

  <div class="chero__stickers" aria-hidden="true">
    <span class="fl" style="--x:52%; --y:16%; --d:7.4s; --r:9deg;   --depth:18">💬</span>
    <span class="fl" style="--x:59%; --y:32%; --d:5.6s; --r:8deg;   --depth:30">💛</span>
    <span class="fl" style="--x:48%; --y:64%; --d:6.6s; --r:-8deg;  --depth:22">🧶</span>
    <span class="fl" style="--x:63%; --y:74%; --d:6s;   --r:-12deg; --depth:26">✨</span>
  </div>

  <div class="chero__inner">
    <div class="chero__copy">
      <p class="chero__eyebrow">{L.eyebrow}</p>
      <h1 class="chero__title">
        {titleWords.map((w, i) => (
          <><span class="w" style={`--i:${i}`}>{w}</span>{' '}</>
        ))}
      </h1>
      <svg class="chero__stitch" viewBox="0 0 240 16" preserveAspectRatio="none" aria-hidden="true">
        <path d="M4 8c8-9 18-9 26 0s18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0" />
      </svg>
      <p class="chero__story">{L.story}</p>
      <div class="chero__cta">
        <a class="cbtn cbtn--wa" href={wa} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.75.46 3.45 1.32 4.95L2 22l5.3-1.38a9.86 9.86 0 0 0 4.73 1.2h.01c5.46 0 9.9-4.44 9.9-9.9 0-2.64-1.03-5.13-2.9-7A9.82 9.82 0 0 0 12.04 2Zm0 1.8c2.17 0 4.2.85 5.74 2.38a8.06 8.06 0 0 1 2.38 5.73c0 4.48-3.65 8.12-8.13 8.12a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.14.82.84-3.06-.2-.31a8.04 8.04 0 0 1-1.24-4.28c0-4.48 3.65-8.12 8.13-8.12ZM8.53 7.33c-.16 0-.42.06-.64.3-.22.24-.85.83-.85 2.02 0 1.2.87 2.35.99 2.51.12.16 1.7 2.6 4.14 3.64.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.44-.59 1.64-1.15.2-.57.2-1.05.14-1.15-.06-.1-.22-.16-.46-.28-.24-.12-1.44-.71-1.66-.79-.22-.08-.38-.12-.55.12-.16.24-.63.79-.77.95-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.2-1.44-1.35-1.68-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.32-.76-1.8-.18-.42-.37-.42-.54-.43h-.46Z"/></svg>
          {t('contact.whatsapp', locale)}
        </a>
        <a class="cbtn cbtn--etsy" href={etsy} target="_blank" rel="noopener">{t('contact.etsy', locale)}</a>
      </div>
      <span class="chero__tag">⏱️ {L.tag}</span>
    </div>
    <div class="chero__art" aria-hidden="true"></div>
  </div>
</section>

<style>
  .chero {
    position: relative; overflow: hidden; isolation: isolate;
    min-height: clamp(480px, 64vh, 640px); display: grid; align-items: center;
    background: radial-gradient(115% 100% at 30% -10%, #FCEBDD 0%, #FBF3EA 45%, var(--bg) 100%);
  }
  .chero::before {
    content: ""; position: absolute; inset: -20%; z-index: -2;
    background: radial-gradient(38% 38% at 24% 30%, rgba(220,160,55,.16), transparent 70%),
                radial-gradient(44% 44% at 80% 66%, rgba(176,83,46,.13), transparent 70%);
    animation: cdrift 16s ease-in-out infinite alternate;
  }
  @keyframes cdrift { from { transform: translate(-3%, -2%) scale(1); } to { transform: translate(3%, 2%) scale(1.08); } }

  /* Mascot illustration, anchored bottom-right */
  .chero__mascot {
    position: absolute; right: clamp(-10px, 3vw, 70px); bottom: 0; z-index: 0;
    width: clamp(290px, 38vw, 520px); height: auto;
    filter: drop-shadow(0 16px 26px rgba(28,26,24,.18));
    translate: var(--kx, 0) var(--ky, 0); animation: cbob 6s ease-in-out infinite; will-change: transform, translate;
  }
  @keyframes cbob { 0%, 100% { transform: rotate(-1.4deg); } 50% { transform: rotate(1.4deg) translateY(-8px); } }

  .chero__stickers { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .fl {
    position: absolute; left: var(--x); top: var(--y); font-size: clamp(1.5rem, 3vw, 2.6rem);
    transform: translate(var(--px, 0), var(--py, 0)) rotate(var(--r));
    animation: cfloaty var(--d) ease-in-out infinite; filter: drop-shadow(0 8px 12px rgba(28,26,24,.14));
    transition: transform 300ms ease-out; will-change: transform;
  }
  @keyframes cfloaty { 0%, 100% { translate: 0 0; } 50% { translate: 0 -15px; } }

  .chero__inner {
    position: relative; z-index: 1; width: 100%; max-width: var(--maxw); margin: 0 auto;
    padding: var(--space-7) var(--space-5);
    display: grid; grid-template-columns: 1.15fr .85fr; gap: var(--space-6); align-items: center;
  }
  .chero__copy { max-width: 39rem; }
  .chero__eyebrow {
    font-family: var(--font-signature); font-size: 1.9rem; color: var(--accent);
    margin: 0 0 var(--space-1); transform: rotate(-2deg); opacity: 0; animation: crise .6s var(--ease) .1s forwards;
  }
  .chero__title {
    font-family: var(--font-display); font-weight: 600; font-size: clamp(2.3rem, 4.6vw, 3.7rem);
    line-height: 1.08; letter-spacing: -.01em; color: var(--ink); margin: 0 0 var(--space-3); text-wrap: balance;
  }
  .chero__title .w { display: inline-block; opacity: 0; animation: cpop .55s var(--ease) both; animation-delay: calc(var(--i) * 60ms + 250ms); }
  .chero__stitch { display: block; width: 120px; height: 15px; margin: 0 0 var(--space-4); overflow: visible; }
  .chero__stitch path { fill: none; stroke: var(--accent); stroke-width: 3; stroke-linecap: round;
    stroke-dasharray: 600; stroke-dashoffset: 600; animation: cstitch 2.2s ease-in-out .9s forwards; }
  .chero__story { color: var(--muted); font-size: 1.14rem; line-height: 1.7; margin: 0 0 var(--space-5); opacity: 0; animation: crise .6s var(--ease) .55s forwards; }

  .chero__cta { display: flex; flex-wrap: wrap; gap: var(--space-3); margin: 0 0 var(--space-4); opacity: 0; animation: crise .6s var(--ease) .72s forwards; }
  .cbtn {
    display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-weight: 600;
    font-size: .98rem; padding: 12px 22px; border-radius: var(--radius-pill); text-decoration: none;
    transition: transform var(--dur, .2s) var(--ease), box-shadow var(--dur, .2s) var(--ease), background var(--dur, .2s) var(--ease);
  }
  .cbtn--wa { background: #25D366; color: #06331a; box-shadow: 0 10px 22px rgba(37,211,102,.30); }
  .cbtn--wa:hover { transform: translateY(-2px); box-shadow: 0 14px 28px rgba(37,211,102,.40); }
  .cbtn--etsy { background: var(--surface); color: var(--ink); border: 1.5px solid var(--line); }
  .cbtn--etsy:hover { transform: translateY(-2px); border-color: var(--accent); color: var(--accent); }
  .cbtn:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .chero__tag {
    display: inline-block; font-family: var(--font-body); font-size: .82rem; font-weight: 600;
    letter-spacing: .04em; color: var(--accent-ink); background: color-mix(in srgb, var(--accent) 12%, transparent);
    padding: 7px 16px; border-radius: var(--radius-pill); opacity: 0; animation: crise .6s var(--ease) .9s forwards;
  }

  @keyframes crise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
  @keyframes cpop { 0% { opacity: 0; transform: translateY(20px) scale(.82) rotate(-5deg); } 100% { opacity: 1; transform: none; } }
  @keyframes cstitch { to { stroke-dashoffset: 0; } }

  @media (max-width: 900px) {
    .chero { min-height: auto; }
    .chero__inner { grid-template-columns: 1fr; padding-bottom: clamp(220px, 42vw, 320px); }
    .chero__copy { max-width: none; text-align: center; margin: 0 auto; }
    .chero__stitch { margin-left: auto; margin-right: auto; }
    .chero__cta { justify-content: center; }
    .chero__mascot { width: clamp(210px, 52vw, 350px); right: 50%; transform: translateX(50%); }
    @keyframes cbob { 0%,100% { transform: translateX(50%) rotate(-1.4deg); } 50% { transform: translateX(50%) rotate(1.4deg) translateY(-8px); } }
  }

  @media (prefers-reduced-motion: reduce) {
    .chero::before, .chero__mascot, .fl { animation: none; }
    .chero__eyebrow, .chero__title .w, .chero__story, .chero__cta, .chero__tag { opacity: 1; animation: none; }
    .chero__stitch path { stroke-dashoffset: 0; animation: none; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const big = window.matchMedia('(min-width: 901px)').matches;
  if (!reduce && big) {
    const hero = document.querySelector<HTMLElement>('.chero');
    const mascot = document.querySelector<HTMLElement>('.chero__mascot');
    const stickers = document.querySelectorAll<HTMLElement>('.chero .fl');
    if (hero) {
      hero.addEventListener('mousemove', (e) => {
        const r = hero.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        stickers.forEach((s) => {
          const depth = parseFloat(s.style.getPropertyValue('--depth')) || 20;
          s.style.setProperty('--px', (x * depth).toFixed(1) + 'px');
          s.style.setProperty('--py', (y * depth).toFixed(1) + 'px');
        });
        if (mascot) { mascot.style.setProperty('--kx', (x * 16).toFixed(1) + 'px'); mascot.style.setProperty('--ky', (y * 9).toFixed(1) + 'px'); }
      }, { passive: true });
      hero.addEventListener('mouseleave', () => {
        stickers.forEach((s) => { s.style.setProperty('--px', '0px'); s.style.setProperty('--py', '0px'); });
        if (mascot) { mascot.style.setProperty('--kx', '0px'); mascot.style.setProperty('--ky', '0px'); }
      });
    }
  }
</script>
