---
import Base from '../layouts/Base.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Locale } from '@lib/i18n';

interface Props {
  locale: Locale;
  title: string;
  updated: string;
  html: string;
  description?: string;
  pathSelf: string;
  pathsAlt: { tr: string; en: string };
}
const { locale, title, updated, html, description, pathSelf, pathsAlt } = Astro.props as Props;
const updatedLabel = locale === 'tr' ? 'Son güncelleme' : 'Last updated';
---
<Base locale={locale} title={`${title} — Aselovers`} description={description || title} pathSelf={pathSelf} pathsAlt={pathsAlt}>
  <Nav locale={locale} />
  <main>
    <section class="section">
      <div class="container legal">
        <header class="legal__head">
          <h1>{title}</h1>
          <p class="legal__updated">{updatedLabel}: {updated}</p>
        </header>
        <article class="legal__body prose" set:html={html} />
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Base>

<style>
  .legal { max-width: 820px; }
  .legal__head { margin-bottom: var(--space-6); padding-bottom: var(--space-4); border-bottom: 1px solid var(--line); }
  .legal__head h1 { font-family: var(--font-display); font-size: clamp(1.9rem, 4vw, 2.8rem); line-height: 1.1; margin: 0 0 var(--space-2); }
  .legal__updated { color: var(--muted); font-size: var(--step-small); margin: 0; }
  .legal__body { color: var(--ink); }
  .legal__body :global(h2) { font-family: var(--font-display); font-size: 1.35rem; margin: var(--space-6) 0 var(--space-3); color: var(--ink); }
  .legal__body :global(h3) { font-family: var(--font-body); font-weight: 600; font-size: 1.08rem; margin: var(--space-4) 0 var(--space-2); }
  .legal__body :global(p) { line-height: 1.75; margin: 0 0 var(--space-3); color: var(--muted); }
  .legal__body :global(ul), .legal__body :global(ol) { margin: 0 0 var(--space-3) 1.2rem; color: var(--muted); line-height: 1.7; }
  .legal__body :global(li) { margin-bottom: 6px; }
  .legal__body :global(a) { color: var(--accent-ink); text-decoration: underline; }
  .legal__body :global(strong) { color: var(--ink); }
  .legal__body :global(.legal-note) { background: color-mix(in srgb, var(--accent) 8%, var(--surface)); border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line)); border-radius: var(--radius); padding: var(--space-3) var(--space-4); font-size: .92rem; margin: 0 0 var(--space-4); }
  .legal__body :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 var(--space-4); font-size: .92rem; }
  .legal__body :global(td), .legal__body :global(th) { border: 1px solid var(--line); padding: 8px 10px; text-align: left; vertical-align: top; }
</style>
