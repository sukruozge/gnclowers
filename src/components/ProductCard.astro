---
import { type Locale } from '@lib/i18n';
import { localizedTitle, productSlug, hasVariations, type Product } from '@lib/products';
import { displayPrice, FALLBACK_RATES, productRates } from '@lib/currency';
import settings from '../data/settings.json';
const { product, locale, quickAdd = false } = Astro.props as { product: Product; locale: Locale; quickAdd?: boolean };
const title = localizedTitle(product, locale);
const href = locale === 'tr'
  ? `/tr/urun/${productSlug(product, 'tr')}`
  : `/en/product/${productSlug(product, 'en')}`;
const rates = (settings as any).rates ?? FALLBACK_RATES;
const price = displayPrice(product.price, locale, productRates(product.price, product.priceUsd, rates));
const altImg = product.images && product.images.length > 1 ? product.images[1] : null;
const addLabel = locale === 'tr' ? 'Sepete ekle' : 'Add to cart';
---
<div class="card">
  <div class="card__media">
    {product.image && <img class="card__img" src={product.image} alt={(locale === 'tr' && product.imageAlt_tr) || product.imageAlt || title} loading="lazy" />}
    {altImg && <img class="card__img card__img--alt" src={altImg} alt="" aria-hidden="true" loading="lazy" />}
    {product.isNew && <span class="card__new">{locale === 'tr' ? 'Yeni' : 'New'}</span>}
    {quickAdd && (
      <button class="card__add" type="button" data-id={product.id} data-href={href} data-opts={hasVariations(product) ? '1' : ''} aria-label={addLabel}>
        <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      </button>
    )}
  </div>
  <a class="card__link" href={href}>
    <h3 class="card__title">{title}</h3>
    <span class="card__price price-amt" data-try={product.price} data-cur={product.currency}>{price}</span>
  </a>
</div>
<style>
  .card { position: relative; transition: transform var(--dur) var(--ease); }
  .card:hover { transform: translateY(-4px); }
  .card__media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; border-radius: var(--radius); background: var(--section); border: 1px solid var(--line); }
  .card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 700ms var(--ease), opacity 500ms var(--ease); }
  .card__img--alt { opacity: 0; }
  .card:hover .card__img { transform: scale(1.05); }
  .card:hover .card__img--alt { opacity: 1; }
  .card__new { position: absolute; top: var(--space-3); left: var(--space-3); z-index: 3; font-size: .66rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; background: var(--surface); color: var(--ink); padding: 4px 10px; border-radius: var(--radius-pill); box-shadow: var(--shadow-glass); }

  .card__add { position: absolute; bottom: 12px; right: 12px; z-index: 3; width: 44px; height: 44px; display: grid; place-items: center; border-radius: 50%; border: 1px solid var(--line); background: var(--surface); color: var(--accent); cursor: pointer; box-shadow: 0 6px 16px rgba(28,26,24,.14); opacity: 0; transform: translateY(8px) scale(.9); transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease), background var(--dur) var(--ease), color var(--dur) var(--ease); }
  .card:hover .card__add, .card:focus-within .card__add { opacity: 1; transform: none; }
  .card__add:hover { background: var(--accent); color: var(--on-accent); transform: scale(1.06); }
  .card__add svg { pointer-events: none; }

  .card__link { display: block; margin-top: var(--space-3); text-align: center; }
  .card__link::after { content: ''; position: absolute; inset: 0; z-index: 1; }
  .card__title { font-size: 1.02rem; font-weight: 500; margin: 0 0 var(--space-1); line-height: 1.35; color: var(--ink); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  /* Centered, high-appeal price — a vivid warm tone that pulls the eye. */
  .card__price { display: block; text-align: center; margin-top: 7px; font-family: var(--font-body); color: #C2410C; font-weight: 800; font-size: 1.24rem; letter-spacing: .01em; font-variant-numeric: tabular-nums; transition: color var(--dur) var(--ease); }
  .card:hover .card__price { color: #9A3412; }

  /* Touch devices have no hover — keep the quick-add button visible. */
  @media (hover: none) {
    .card__add { opacity: 1; transform: none; }
  }
</style>
