---
import { t, type Locale } from '@lib/i18n';
import StarRating from '../StarRating.astro';
import Ambient from '../Ambient.astro';
import { loadReviews, pickReviews } from '@lib/reviews';

const { locale } = Astro.props as { locale: Locale };

interface Testimonial {
  text: string;
  name: string;
  role: string;
  rating: number;
  color: string;
}

// Real, verifiable Etsy reviews (src/data/reviews.json) — no invented names/roles.
const PALETTE = ['#B0532E', '#6F8B6A', '#5E7A9B', '#C08552', '#A9746E', '#8D7BA5', '#5F8A86', '#C0873E', '#B0708F'];
const buyerLabel = locale === 'tr' ? 'Etsy Alıcısı' : 'Etsy Buyer';
const verifiedLabel = locale === 'tr' ? 'Doğrulanmış satın alma' : 'Verified purchase';
const fmtDate = (d: string) => { try { return new Date(d).toLocaleDateString(locale === 'tr' ? 'tr-TR' : 'en-US', { month: 'short', year: 'numeric' }); } catch { return ''; } };
const realReviews = pickReviews(loadReviews().reviews, locale, 9);
const testimonials: Testimonial[] = realReviews.map((r, i) => ({
  text: r.text,
  name: buyerLabel,
  role: verifiedLabel + (r.date ? ' · ' + fmtDate(r.date) : ''),
  rating: r.rating,
  color: PALETTE[i % PALETTE.length],
}));

// Distribute the real reviews across the 3 scrolling columns (round-robin so short
// lists stay balanced); each column is duplicated in the template for seamless scroll.
const firstColumn = testimonials.filter((_, i) => i % 3 === 0);
const secondColumn = testimonials.filter((_, i) => i % 3 === 1);
const thirdColumn = testimonials.filter((_, i) => i % 3 === 2);

const initials = (_name: string) => '★';
---
<section class="section section--tint testimonials-section" aria-labelledby="testimonials-heading">
  <Ambient variant="tint" />
  <div class="container testimonials-inner reveal">
    
    <!-- Heading -->
    <div class="testimonials-head">
      <div class="badge-wrapper">
        <span class="testimonials-badge">{t('reviews.eyebrow', locale)}</span>
      </div>
      <h2 id="testimonials-heading">{t('reviews.title', locale)}</h2>
      <p class="subtitle">
        {locale === 'tr'
          ? 'Etsy’de 5.0★ — alıcılarımızın kendi sözleriyle, doğrulanmış satın almalar.'
          : '5.0★ on Etsy — in our buyers’ own words, from verified purchases.'}
      </p>
    </div>

    <!-- Scrolling Grid Region -->
    <div class="scrolling-grid" role="region" aria-label="Scrolling Testimonials">
      
      <!-- Col 1 -->
      <div class="scroll-col scroll-col--1">
        <ul class="scroll-col__list animation-dur-15">
          {[...firstColumn, ...firstColumn].map((r, i) => (
            <li class="testimonial-card">
              <div class="card-stars">
                <StarRating rating={r.rating} />
              </div>
              <blockquote class="card-text">“{r.text}”</blockquote>
              <div class="card-meta">
                <span class="card-avatar" style={`background:${r.color}`}>{initials(r.name)}</span>
                <div class="card-info">
                  <cite class="card-name">{r.name}</cite>
                  <span class="card-role">{r.role}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 2 -->
      <div class="scroll-col scroll-col--2">
        <ul class="scroll-col__list animation-dur-19">
          {[...secondColumn, ...secondColumn].map((r, i) => (
            <li class="testimonial-card">
              <div class="card-stars">
                <StarRating rating={r.rating} />
              </div>
              <blockquote class="card-text">“{r.text}”</blockquote>
              <div class="card-meta">
                <span class="card-avatar" style={`background:${r.color}`}>{initials(r.name)}</span>
                <div class="card-info">
                  <cite class="card-name">{r.name}</cite>
                  <span class="card-role">{r.role}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3 -->
      <div class="scroll-col scroll-col--3">
        <ul class="scroll-col__list animation-dur-17">
          {[...thirdColumn, ...thirdColumn].map((r, i) => (
            <li class="testimonial-card">
              <div class="card-stars">
                <StarRating rating={r.rating} />
              </div>
              <blockquote class="card-text">“{r.text}”</blockquote>
              <div class="card-meta">
                <span class="card-avatar" style={`background:${r.color}`}>{initials(r.name)}</span>
                <div class="card-info">
                  <cite class="card-name">{r.name}</cite>
                  <span class="card-role">{r.role}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Foot Link Removed -->

  </div>
</section>

<style>
  .testimonials-section {
    position: relative;
    padding: var(--space-8) 0;
    overflow: hidden;
  }
  .testimonials-inner { position: relative; z-index: 1; }

  .testimonials-head {
    max-width: 580px;
    margin: 0 auto var(--space-6);
    text-align: center;
  }
  
  .badge-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3);
  }
  
  .testimonials-badge {
    display: inline-block;
    border: 1px solid var(--line);
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted);
    background: rgba(255,255,255,0.5);
  }

  .testimonials-head h2 {
    font-size: var(--step-h2);
    color: var(--ink);
    margin: 0 0 var(--space-3);
  }

  .testimonials-head .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Scrolling Grid layout */
  .scrolling-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-5);
    margin-top: var(--space-6);
    max-height: 680px;
    overflow: hidden;
    position: relative;
    /* Masking gradient at top and bottom to fade out edge cards */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .scroll-col {
    flex: 1;
    max-width: 340px;
    display: flex;
    flex-direction: column;
  }

  .scroll-col__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: 0 0 var(--space-4);
    margin: 0;
    list-style: none;
    animation: scrollVertical 20s linear infinite;
  }

  /* Different scrolling speeds */
  .animation-dur-15 { animation-duration: 25s; }
  .animation-dur-19 { animation-duration: 32s; }
  .animation-dur-17 { animation-duration: 28s; }

  /* Infinite Scroll Keyframes */
  @keyframes scrollVertical {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  /* Hover to pause column scroll */
  .scroll-col:hover .scroll-col__list {
    animation-play-state: paused;
  }

  /* Cards inside columns */
  .testimonial-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    box-shadow: 0 4px 12px rgba(28, 26, 24, 0.02);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
    cursor: default;
    user-select: none;
  }

  .testimonial-card:hover {
    transform: scale(1.03) translateY(-6px);
    box-shadow: 0 20px 40px rgba(28, 26, 24, 0.08);
    border-color: rgba(176, 83, 46, 0.2); /* var(--accent) match */
  }

  .card-stars {
    display: flex;
    justify-content: flex-start;
  }

  .card-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink);
    font-weight: 400;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .card-avatar {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 7px rgba(28, 26, 24, 0.14);
  }

  .card-info {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .card-name {
    font-style: normal;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ink);
  }

  .card-role {
    font-size: 0.76rem;
    color: var(--muted);
    margin-top: 2px;
  }

  .testimonials-foot {
    text-align: center;
    margin-top: var(--space-6);
  }

  .reviews-see-all {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--accent);
    border-bottom: 1.5px solid transparent;
    padding-bottom: 2px;
    transition: border-color var(--dur) var(--ease);
  }
  
  .reviews-see-all:hover {
    border-color: var(--accent);
  }

  /* Responsive Rules */
  @media (max-width: 900px) {
    .scroll-col--3 {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .scroll-col--2 {
      display: none;
    }
    .scrolling-grid {
      max-height: 480px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-col__list {
      animation: none;
    }
  }
</style>
