---
import { t, type Locale } from '@lib/i18n';
import { loadProducts } from '@lib/products';
import SectionHeading from '../SectionHeading.astro';
import Ambient from '../Ambient.astro';
import settings from '../../data/settings.json';

const { locale } = Astro.props as { locale: Locale };
const products = loadProducts();

const catLabels: Record<string, Record<Locale, string>> = {
  'Crochet Bags': { tr: 'Örgü Çantalar', en: 'Crochet Bags' },
  'Safari Animals': { tr: 'Safari Hayvanları', en: 'Safari Animals' },
  'Curtain Tiebacks': { tr: 'Perde Tutacakları', en: 'Curtain Tiebacks' },
  'Amigurumi Toys': { tr: 'Amigurumi Oyuncaklar', en: 'Amigurumi Toys' },
  'Baby Gift Sets': { tr: 'Bebek Hediye Setleri', en: 'Baby Gift Sets' },
  'Stuffed Animals': { tr: 'Peluş Oyuncaklar', en: 'Stuffed Animals' },
  'Crochet Dolls': { tr: 'Örgü Bebekler', en: 'Crochet Dolls' },
  'Bunny Rabbits Toys': { tr: 'Örgü Tavşanlar', en: 'Bunny Rabbits Toys' },
  'Baby Shower': { tr: 'Bebek Partisi', en: 'Baby Shower' },
  'Crochet Hair Clips': { tr: 'Örgü Saç Tokaları', en: 'Crochet Hair Clips' },
  'Wedding Dolls': { tr: 'Düğün Bebekleri', en: 'Wedding Dolls' }
};

const REPRESENTATIVE_IMAGES: Record<string, string> = {
  'Crochet Bags': settings.categoryCovers?.['Crochet Bags'] || '/images/categories/bags.png',
  'Safari Animals': settings.categoryCovers?.['Safari Animals'] || '/images/categories/safari.png',
  'Curtain Tiebacks': settings.categoryCovers?.['Curtain Tiebacks'] || '/images/categories/tiebacks.png',
  'Amigurumi Toys': settings.categoryCovers?.['Amigurumi Toys'] || '/images/categories/toys.png',
  'Baby Gift Sets': settings.categoryCovers?.['Baby Gift Sets'] || '/images/categories/giftsets.png',
  'Stuffed Animals': settings.categoryCovers?.['Stuffed Animals'] || settings.categoryCovers?.['Amigurumi Toys'] || '/images/categories/toys.png',
  'Crochet Dolls': settings.categoryCovers?.['Crochet Dolls'] || '/images/categories/dolls.png',
  'Bunny Rabbits Toys': settings.categoryCovers?.['Bunny Rabbits Toys'] || '/images/categories/bunny.png',
  'Baby Shower': settings.categoryCovers?.['Baby Shower'] || settings.categoryCovers?.['Baby Gift Sets'] || '/images/categories/giftsets.png',
  'Crochet Hair Clips': settings.categoryCovers?.['Crochet Hair Clips'] || '/images/categories/hairclips.png',
  'Wedding Dolls': settings.categoryCovers?.['Wedding Dolls'] || settings.categoryCovers?.['Crochet Dolls'] || '/images/categories/dolls.png'
};

const cats = [...new Set(products.map((p) => p.category))]
  .map((c) => {
    const items = products.filter((p) => p.category === c);
    const sample = items.find((p) => p.image);
    const chosenImage = REPRESENTATIVE_IMAGES[c] ?? sample?.image;
    const label = catLabels[c]?.[locale] ?? c;
    return { c, label, img: chosenImage, alt: label, count: items.length };
  })
  .filter((cat) => cat.img)
  .slice(0, 8);

const catalog = locale === 'tr' ? '/tr/urunler' : '/en/products';
const unit = locale === 'tr' ? 'ürün' : 'items';
const exploreLabel = locale === 'tr' ? 'Keşfet' : 'Explore';
---
<section class="section cats-section">
  <Ambient variant="warm" />
  <div class="container cats-container">
    <div class="reveal reveal--fade-up">
      <SectionHeading title={t('home.categories', locale)} />
    </div>
    <div class="cats">
      {cats.map((cat, idx) => (
        <a class={`cat reveal reveal--fade-up reveal--d${(idx % 4) + 1}`} href={`${catalog}?cat=${encodeURIComponent(cat.c)}`}>
          <div class="cat__media">
            {cat.img && <img src={cat.img} alt={cat.alt} loading="lazy" />}
            <div class="cat__overlay">
              <span class="cat__overlay-btn">
                {exploreLabel}
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
              </span>
            </div>
          </div>
          <span class="cat__label">{cat.label}</span>
          <svg class="cat__stitch" viewBox="0 0 64 6" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 4 Q10 0 18 4 T34 4 T50 4 T62 4" />
          </svg>
          {cat.count > 0 && <span class="cat__count">{cat.count} {unit}</span>}
        </a>
      ))}
    </div>
  </div>
</section>
<style>
  .cats-section { position: relative; overflow: hidden; }
  .cats-container { position: relative; z-index: 1; }
  .cats {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: var(--space-7) var(--space-5);
  }
  .cat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform var(--dur) var(--ease);
  }
  .cat:hover { transform: translateY(-6px); }

  .cat__media {
    position: relative;
    width: 100%;
    aspect-ratio: 9/12;
    overflow: hidden;
    border-radius: 130px 130px var(--radius) var(--radius);
    background: var(--section);
    border: 1px solid var(--line);
    box-shadow: 0 10px 30px rgba(28, 26, 24, 0.05);
    transition: box-shadow var(--dur) var(--ease);
  }
  .cat:hover .cat__media { box-shadow: 0 20px 46px rgba(28, 26, 24, 0.13); }
  .cat__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }
  .cat:hover .cat__media img { transform: scale(1.07); }

  /* Warm terracotta-tinted reveal with a glass "Explore" pill */
  .cat__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(133, 58, 27, 0.62) 0%, rgba(133, 58, 27, 0.12) 42%, transparent 72%);
    opacity: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: var(--space-5);
    transition: opacity var(--dur) var(--ease);
  }
  .cat__overlay-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #fff;
    font-size: var(--step-small);
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 8px 17px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.75);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    transform: translateY(8px);
    transition: transform var(--dur) var(--ease);
  }
  .cat:hover .cat__overlay { opacity: 1; }
  .cat:hover .cat__overlay-btn { transform: translateY(0); }

  .cat__label {
    display: block;
    font-family: var(--font-display);
    font-size: 1.28rem;
    font-weight: 500;
    margin-top: var(--space-4);
    color: var(--ink);
    transition: color var(--dur) var(--ease);
  }
  .cat:hover .cat__label { color: var(--accent-ink); }

  /* Signature hand-stitch (running-stitch) accent under each name */
  .cat__stitch {
    display: block;
    width: 58px;
    height: 6px;
    margin: 10px auto 0;
  }
  .cat__stitch path {
    fill: none;
    stroke: rgba(176, 83, 46, 0.45);
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-dasharray: 4 3.5;
    transition: stroke var(--dur) var(--ease);
  }
  .cat:hover .cat__stitch path { stroke: var(--accent); }

  /* Product count under the stitch accent */
  .cat__count {
    display: block;
    margin-top: 8px;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .cat, .cat__media, .cat__media img, .cat__overlay-btn { transition: none; }
    .cat:hover { transform: none; }
  }
</style>
