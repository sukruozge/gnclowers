---
import { t, type Locale } from '@lib/i18n';

const { locale } = Astro.props as { locale: Locale };
const isTr = locale === 'tr';
const aboutHref = isTr ? '/tr/hakkimizda' : '/en/about';

const title = t('process.title', locale);
// Split into words (keeps whole words unbreakable) while still animating per-letter.
let _li = 0;
const titleWords = title.split(' ').map((w) => [...w].map((ch) => ({ ch, i: _li++ })));

const steps = [1, 2, 3].map((n) => ({
  n,
  title: t(`process.step${n}Title`, locale),
  body: t(`process.step${n}Body`, locale),
  img: `/images/process/step${n}.png`,
}));

const L = isTr
  ? {
      sub: 'Bir iplik yumağından kucağınıza gelen oyuncağa kadar — her adımı sabırla, elde ve sevgiyle yapıyoruz.',
      chips: ['Yumuşak pamuk iplik', 'Elde tığ işi', '%100 el emeği', 'Siparişe özel', 'Türkiye & ABD’ye kargo'],
      alts: ['Yumuşak pamuk iplik ve tığ ile tasarım', 'Amigurumi oyuncağın elde örülmesi', 'Özenle paketlenmiş el yapımı hediye'],
    }
  : {
      sub: 'From a single ball of yarn to the toy in your arms — every step is done patiently, by hand, with love.',
      chips: ['Soft cotton yarn', 'Hand-crocheted', '100% handmade', 'Made to order', 'Ships to Türkiye & US'],
      alts: ['Design with soft cotton yarn and a hook', 'Crocheting the amigurumi toy by hand', 'Carefully packaged handmade gift'],
    };
const cta = t('home.storyCta', locale);
const eyebrow = t('process.eyebrow', locale);
---
<section class="pj section">
  <span class="pj__fl" style="--x:8%;  --y:22%; --d:7s;   --r:-10deg" aria-hidden="true">🧶</span>
  <span class="pj__fl" style="--x:93%; --y:16%; --d:6.2s; --r:12deg"  aria-hidden="true">🪡</span>
  <span class="pj__fl" style="--x:88%; --y:78%; --d:8s;   --r:-8deg"  aria-hidden="true">🧵</span>

  <div class="container">
    <header class="pj__head reveal">
      <p class="pj__eyebrow">{eyebrow}</p>
      <h2 class="pj__title" aria-label={title}>
        {titleWords.map((word, wi) => (
          <>
            <span class="pj__word">
              {word.map(({ ch, i }) => (
                <span class="pj__ltr" style={`--i:${i}`} aria-hidden="true">{ch}</span>
              ))}
            </span>
            {wi < titleWords.length - 1 ? ' ' : ''}
          </>
        ))}
      </h2>
      <svg class="pj__stitch" viewBox="0 0 240 16" preserveAspectRatio="none" aria-hidden="true">
        <path d="M4 8c8-9 18-9 26 0s18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0" />
      </svg>
      <p class="pj__sub">{L.sub}</p>
    </header>

    <div class="pj__steps">
      <svg class="pj__thread reveal" viewBox="0 0 1000 40" preserveAspectRatio="none" aria-hidden="true">
        <path d="M10 20 C 130 -8, 210 48, 340 20 S 620 -8, 660 20 S 880 48, 990 20" />
      </svg>

      {steps.map((s, i) => (
        <article class={`pj__step reveal reveal--fade-up reveal--d${i + 1}`}>
          <div class="pj__num">{s.n}</div>
          <div class="pj__photo">
            <img src={s.img} alt={L.alts[i]} loading="lazy" decoding="async" width="600" height="800" />
          </div>
          <h3 class="pj__stitle">{s.title}</h3>
          <p class="pj__sbody">{s.body}</p>
        </article>
      ))}
    </div>

    <ul class="pj__chips">
      {L.chips.map((c, i) => (
        <li class={`pj__chip reveal reveal--fade-up reveal--d${Math.min(i + 1, 4)}`}>
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
          {c}
        </li>
      ))}
    </ul>

    <div class="pj__cta reveal reveal--fade-up">
      <a class="pj__btn" href={aboutHref}>
        {cta}
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .pj {
    position: relative; overflow: hidden; isolation: isolate;
    background: radial-gradient(120% 90% at 50% -10%, #FCEEE1 0%, #FBF4EC 45%, var(--bg) 100%);
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .pj::before {
    content: ""; position: absolute; inset: -20%; z-index: -2;
    background: radial-gradient(36% 36% at 18% 26%, rgba(220,160,55,.14), transparent 70%),
                radial-gradient(40% 40% at 84% 72%, rgba(176,83,46,.12), transparent 70%);
    animation: pjdrift 17s ease-in-out infinite alternate;
  }
  @keyframes pjdrift { from { transform: translate(-2%, -2%); } to { transform: translate(2%, 2%); } }

  .pj__fl {
    position: absolute; left: var(--x); top: var(--y); font-size: clamp(1.4rem, 2.6vw, 2.3rem);
    transform: rotate(var(--r)); animation: pjfloat var(--d) ease-in-out infinite;
    filter: drop-shadow(0 8px 12px rgba(28,26,24,.12)); z-index: 0; pointer-events: none;
  }
  @keyframes pjfloat { 0%,100% { translate: 0 0; } 50% { translate: 0 -14px; } }

  /* Heading (letter reveal + self-drawing stitch), driven by site-wide .is-visible */
  .pj__head { text-align: center; max-width: 44rem; margin: 0 auto var(--space-7); }
  .pj__eyebrow {
    font-family: var(--font-signature); font-size: 1.9rem; color: var(--accent);
    margin: 0 0 var(--space-1); transform: rotate(-2deg);
    opacity: 0; translate: 0 10px; transition: opacity .6s var(--ease), translate .6s var(--ease);
  }
  .pj__title {
    font-family: var(--font-display); font-weight: 600; font-size: clamp(2.2rem, 4.8vw, 3.6rem);
    line-height: 1.06; letter-spacing: -.01em; color: var(--ink); margin: 0; text-wrap: balance;
  }
  .pj__word { display: inline-block; white-space: nowrap; }
  .pj__ltr {
    display: inline-block; opacity: 0; transform: translateY(22px) rotate(-6deg) scale(.82);
    transition: opacity .5s var(--ease), transform .55s cubic-bezier(.34,1.5,.5,1);
    transition-delay: calc(var(--i) * 38ms);
  }
  .pj__stitch { display: block; width: 150px; height: 15px; margin: var(--space-2) auto var(--space-3); overflow: visible; }
  .pj__stitch path {
    fill: none; stroke: var(--accent); stroke-width: 3; stroke-linecap: round;
    stroke-dasharray: 600; stroke-dashoffset: 600; transition: stroke-dashoffset 1.6s var(--ease) .3s;
  }
  .pj__sub { color: var(--muted); font-size: 1.12rem; line-height: 1.65; margin: 0; opacity: 0; translate: 0 10px; transition: opacity .6s var(--ease) .2s, translate .6s var(--ease) .2s; }

  .pj__head.is-visible .pj__eyebrow { opacity: 1; translate: 0 0; }
  .pj__head.is-visible .pj__ltr { opacity: 1; transform: none; }
  .pj__head.is-visible .pj__stitch path { stroke-dashoffset: 0; }
  .pj__head.is-visible .pj__sub { opacity: 1; translate: 0 0; }

  /* Steps row + connecting yarn thread */
  .pj__steps { position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .pj__thread { position: absolute; top: 20px; left: 15%; right: 15%; width: 70%; height: 40px; z-index: 0; overflow: visible; }
  .pj__thread path {
    fill: none; stroke: color-mix(in srgb, var(--accent) 55%, transparent); stroke-width: 3; stroke-linecap: round;
    stroke-dasharray: 6 12; stroke-dashoffset: 1400; transition: stroke-dashoffset 2.4s var(--ease) .2s;
  }
  .pj__thread.is-visible path { stroke-dashoffset: 0; }

  .pj__step { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pj__num {
    display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%;
    background: var(--accent); color: #fff; font-family: var(--font-display); font-weight: 700; font-size: 1.3rem;
    box-shadow: 0 8px 18px color-mix(in srgb, var(--accent) 40%, transparent); margin-bottom: var(--space-4);
    border: 4px solid var(--bg);
  }
  .pj__photo {
    width: 100%; max-width: 320px; aspect-ratio: 3 / 4; border-radius: var(--radius-lg); overflow: hidden;
    border: 6px solid #fff; background: var(--section); box-shadow: 0 16px 34px rgba(28,26,24,.14);
    transition: transform .5s var(--ease), box-shadow .5s var(--ease); will-change: transform;
  }
  .pj__step:nth-child(2) .pj__photo { transform: rotate(-2deg); }
  .pj__step:nth-child(3) .pj__photo { transform: rotate(1.5deg); }
  .pj__step:nth-child(4) .pj__photo { transform: rotate(-1.5deg); }
  .pj__photo:hover { transform: translateY(-8px) rotate(0deg) scale(1.02); box-shadow: 0 26px 44px rgba(28,26,24,.20); }
  .pj__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pj__stitle { font-family: var(--font-display); font-weight: 600; font-size: 1.4rem; color: var(--ink); margin: var(--space-4) 0 var(--space-2); }
  .pj__sbody { color: var(--muted); font-size: var(--step-small); line-height: 1.65; margin: 0; max-width: 30ch; }

  /* Quality chips */
  .pj__chips { list-style: none; margin: var(--space-7) 0 0; padding: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-2) var(--space-3); }
  .pj__chip {
    display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-body); font-weight: 600;
    font-size: .82rem; color: var(--accent-ink); background: color-mix(in srgb, var(--accent) 10%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line)); padding: 8px 15px; border-radius: var(--radius-pill);
  }
  .pj__chip svg { color: var(--accent); flex-shrink: 0; }

  .pj__cta { text-align: center; margin-top: var(--space-6); }
  .pj__btn {
    display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-weight: 600;
    font-size: 1rem; padding: 13px 26px; border-radius: var(--radius-pill); text-decoration: none;
    background: var(--accent); color: #fff; box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 38%, transparent);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .pj__btn:hover { transform: translateY(-2px); box-shadow: 0 16px 32px color-mix(in srgb, var(--accent) 46%, transparent); }
  .pj__btn:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; }

  @media (max-width: 820px) {
    .pj__steps { grid-template-columns: 1fr; gap: var(--space-7); max-width: 380px; margin: 0 auto; }
    .pj__thread { display: none; }
    .pj__step:nth-child(n) .pj__photo { transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pj::before, .pj__fl { animation: none; }
    .pj__eyebrow, .pj__ltr, .pj__sub { opacity: 1 !important; translate: 0 !important; transform: none !important; transition: none; }
    .pj__stitch path, .pj__thread path { stroke-dashoffset: 0 !important; transition: none; }
    .pj__photo { transition: none; }
  }
</style>
