---
import { t, type Locale } from '@lib/i18n';
import { StorySection } from '../ui/story-section';

const { locale } = Astro.props as { locale: Locale };
const pth = (tr: string, en: string) => (locale === 'tr' ? `/tr/${tr}` : `/en/${en}`);

const steps = [1, 2, 3].map((n) => ({
  n,
  t: t(`process.step${n}Title`, locale),
  b: t(`process.step${n}Body`, locale)
}));
---

<StorySection
  client:visible
  locale={locale}
  eyebrow={t('process.eyebrow', locale)}
  title={t('process.title', locale)}
  steps={steps}
  buttonText={t('home.storyCta', locale)}
  buttonLink={pth('hakkimizda', 'about')}
  imageUrl1="/images/categories/bags.png"
  imageUrl2="/images/categories/bunny.png"
/>
