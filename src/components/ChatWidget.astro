---
import { type Locale } from '@lib/i18n';
const { locale = 'tr' } = Astro.props as { locale: Locale };

const titleText = locale === 'en' ? 'Ask a Question' : 'Soru Sorun';
const namePlaceholder = locale === 'en' ? 'Your Name' : 'Adınız';
const emailPlaceholder = locale === 'en' ? 'Your Email (Optional)' : 'E-posta (İsteğe Bağlı)';
const messagePlaceholder = locale === 'en' ? 'Type your message...' : 'Sorunuzu buraya yazın...';
const sendText = locale === 'en' ? 'Send' : 'Gönder';
const supportHeader = locale === 'en' ? 'Aselovers Support' : 'Aselovers Destek';
const supportSub = locale === 'en' ? 'We typically reply within a few hours' : 'Genellikle birkaç saat içinde yanıtlıyoruz';
const welcomeText = locale === 'en' 
  ? 'Hello! If you have any questions about our products or your order, feel free to ask here. Please leave your name and email so we can reach you.'
  : 'Merhaba! Ürünlerimiz veya siparişiniz hakkında merak ettiğiniz her şeyi buradan sorabilirsiniz. Size ulaşabilmemiz için adınızı ve e-postanızı bırakmayı unutmayın.';
---

<div class="chat-widget-wrapper">
  <!-- Chat Panel -->
  <div class="chat-panel" id="chat-panel">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-header-avatar">🧶</div>
        <div>
          <h4 class="chat-header-title">{supportHeader}</h4>
          <p class="chat-header-sub">{supportSub}</p>
        </div>
      </div>
      <button class="chat-close-btn" id="chat-close-btn" aria-label="Close chat">×</button>
    </div>
    
    <div class="chat-messages" id="chat-messages">
      <div class="chat-bubble chat-bubble-admin">
        <p class="chat-bubble-text">{welcomeText}</p>
        <span class="chat-bubble-time">System</span>
      </div>
    </div>
    
    <div class="chat-footer">
      <div class="chat-user-info" id="chat-user-fields">
        <input type="text" id="chat-name" class="chat-input-field" placeholder={namePlaceholder} />
        <input type="email" id="chat-email" class="chat-input-field" placeholder={emailPlaceholder} />
      </div>
      <div class="chat-input-row">
        <textarea id="chat-msg" class="chat-textarea" placeholder={messagePlaceholder} rows="1"></textarea>
        <button id="chat-send-btn" class="chat-send-btn" aria-label="Send message">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Float Trigger Button -->
  <button class="chat-trigger-btn" id="chat-trigger-btn" aria-label={titleText}>
    <span class="chat-icon-open">💬</span>
    <span class="chat-icon-close">×</span>
    <span class="chat-badge" id="chat-badge" style="display: none;">1</span>
  </button>
</div>

<style>
  .chat-widget-wrapper {
    position: fixed;
    left: 20px;
    bottom: 20px;
    z-index: 9999;
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* Trigger Button */
  .chat-trigger-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #5969ff;
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(89, 105, 255, 0.4);
    display: grid;
    place-items: center;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.2s;
    position: relative;
  }
  .chat-trigger-btn:hover {
    transform: scale(1.08);
    background: #4758f5;
  }
  .chat-trigger-btn:active {
    transform: scale(0.95);
  }
  .chat-trigger-btn span {
    font-size: 1.5rem;
    grid-area: 1/1;
    transition: transform 0.25s, opacity 0.25s;
  }
  .chat-icon-close {
    opacity: 0;
    transform: rotate(-90deg);
  }
  
  /* Chat Badge */
  .chat-badge {
    position: absolute;
    top: -2px;
    right: -2px;
    background: #ff407b;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: 2px solid #fff;
    box-shadow: 0 2px 6px rgba(255, 64, 123, 0.3);
  }

  /* Chat Panel */
  .chat-panel {
    position: absolute;
    bottom: 72px;
    left: 0;
    width: 350px;
    height: 480px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  :global(.dark-theme) .chat-panel {
    background: rgba(15, 23, 42, 0.95);
    border-color: rgba(51, 65, 85, 0.8);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .chat-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Header */
  .chat-header {
    background: #5969ff;
    color: #fff;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .chat-header-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: grid;
    place-items: center;
    font-size: 1.2rem;
  }
  .chat-header-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
  }
  .chat-header-sub {
    font-size: 0.72rem;
    opacity: 0.85;
    margin: 2px 0 0 0;
  }
  .chat-close-btn {
    background: none;
    border: none;
    color: #fff;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .chat-close-btn:hover {
    opacity: 1;
  }

  /* Messages Area */
  .chat-messages {
    flex: 1;
    padding: 16px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: #f8fafc;
  }
  :global(.dark-theme) .chat-messages {
    background: #0b0f19;
  }

  .chat-bubble {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.85rem;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
  .chat-bubble-admin {
    background: #fff;
    color: #334155;
    align-self: flex-start;
    border-bottom-left-radius: 2px;
    border: 1px solid #e2e8f0;
  }
  :global(.dark-theme) .chat-bubble-admin {
    background: #1e293b;
    color: #f1f5f9;
    border-color: #334155;
  }
  .chat-bubble-user {
    background: #5969ff;
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 2px;
  }
  .chat-bubble-text {
    margin: 0;
    word-break: break-word;
  }
  .chat-bubble-time {
    font-size: 0.65rem;
    opacity: 0.7;
    align-self: flex-end;
  }

  /* Footer / Input Area */
  .chat-footer {
    padding: 12px;
    border-top: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #fff;
  }
  :global(.dark-theme) .chat-footer {
    border-color: #334155;
    background: #0f172a;
  }
  
  .chat-user-info {
    display: flex;
    gap: 8px;
  }
  
  .chat-input-field {
    flex: 1;
    padding: 6px 10px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 0.75rem;
    outline: none;
    background: #fff;
    color: #0f172a;
  }
  :global(.dark-theme) .chat-input-field {
    border-color: #475569;
    background: #1e293b;
    color: #f1f5f9;
  }

  .chat-input-row {
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }

  .chat-textarea {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #cbd5e1;
    border-radius: 20px;
    font-size: 0.85rem;
    outline: none;
    resize: none;
    font-family: inherit;
    line-height: 1.3;
    max-height: 80px;
    background: #fff;
    color: #0f172a;
  }
  :global(.dark-theme) .chat-textarea {
    border-color: #475569;
    background: #1e293b;
    color: #f1f5f9;
  }

  .chat-send-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #5969ff;
    color: #fff;
    border: none;
    cursor: pointer;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: background-color 0.2s, transform 0.1s;
  }
  .chat-send-btn:hover {
    background: #4758f5;
  }
  .chat-send-btn:active {
    transform: scale(0.92);
  }

  /* Responsive screen sizing */
  @media (max-width: 400px) {
    .chat-panel {
      width: calc(100vw - 40px);
      height: 400px;
    }
  }
</style>

<script>
  let chatUserId = localStorage.getItem('ase_chat_user_id');
  if (!chatUserId) {
    chatUserId = 'usr-' + Math.random().toString(36).substring(2, 15) + '-' + Date.now();
    localStorage.setItem('ase_chat_user_id', chatUserId);
  }

  let chatHistory: any[] = [];
  let isPanelOpen = false;
  let unreadReplies = 0;
  let pollInterval: any = null;

  const panel = document.getElementById('chat-panel')!;
  const triggerBtn = document.getElementById('chat-trigger-btn')!;
  const closeBtn = document.getElementById('chat-close-btn')!;
  const messagesContainer = document.getElementById('chat-messages')!;
  const nameInput = document.getElementById('chat-name') as HTMLInputElement;
  const emailInput = document.getElementById('chat-email') as HTMLInputElement;
  const msgInput = document.getElementById('chat-msg') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send-btn')!;
  const badge = document.getElementById('chat-badge')!;
  const userFields = document.getElementById('chat-user-fields')!;

  // Toggle Panel
  const toggleChat = () => {
    isPanelOpen = !isPanelOpen;
    panel.classList.toggle('open', isPanelOpen);
    
    // Rotate/Change icons
    const openIcon = triggerBtn.querySelector('.chat-icon-open') as HTMLElement;
    const closeIcon = triggerBtn.querySelector('.chat-icon-close') as HTMLElement;
    if (isPanelOpen) {
      openIcon.style.opacity = '0';
      openIcon.style.transform = 'rotate(90deg) scale(0.5)';
      closeIcon.style.opacity = '1';
      closeIcon.style.transform = 'rotate(0) scale(1)';
      
      // Clear badge
      unreadReplies = 0;
      badge.style.display = 'none';
      
      // Load messages
      loadMessages();
      startPolling();
    } else {
      openIcon.style.opacity = '1';
      openIcon.style.transform = 'rotate(0) scale(1)';
      closeIcon.style.opacity = '0';
      closeIcon.style.transform = 'rotate(-90deg) scale(0.5)';
      stopPolling();
    }
  };

  triggerBtn.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  // Load name and email from local settings if previously set
  const savedName = localStorage.getItem('ase_chat_name');
  const savedEmail = localStorage.getItem('ase_chat_email');
  if (savedName) nameInput.value = savedName;
  if (savedEmail) {
    emailInput.value = savedEmail;
    userFields.style.display = 'none'; // Hide if already supplied
  }

  // Load chat messages
  async function loadMessages() {
    try {
      const res = await fetch(`/api/messages?userId=${chatUserId}`);
      if (res.ok) {
        const data = await res.json();
        chatHistory = data.messages || [];
        renderMessages();
      }
    } catch {}
  }

  function renderMessages() {
    // Keep initial welcome message
    const welcomeBubble = messagesContainer.firstElementChild;
    messagesContainer.innerHTML = '';
    if (welcomeBubble) messagesContainer.appendChild(welcomeBubble);

    chatHistory.forEach(m => {
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble chat-bubble-${m.sender}`;
      
      const time = new Date(m.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      
      bubble.innerHTML = `
        <p class="chat-bubble-text">${escapeHtml(m.text)}</p>
        <span class="chat-bubble-time">${time}</span>
      `;
      messagesContainer.appendChild(bubble);
    });

    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  // Auto-grow textarea
  msgInput.addEventListener('input', () => {
    msgInput.style.height = 'auto';
    msgInput.style.height = msgInput.scrollHeight + 'px';
  });

  // Send message
  async function sendMessage() {
    const text = msgInput.value.trim();
    if (!text) return;

    const name = nameInput.value.trim();
    const email = emailInput.value.trim();

    if (name) localStorage.setItem('ase_chat_name', name);
    if (email) {
      localStorage.setItem('ase_chat_email', email);
      userFields.style.display = 'none';
    }

    // Append temporarily locally (optimistic)
    const tempMsg = {
      id: 'temp-' + Date.now(),
      sender: 'user',
      text,
      createdAt: new Date().toISOString()
    };
    chatHistory.push(tempMsg);
    renderMessages();
    msgInput.value = '';
    msgInput.style.height = 'auto';

    const isEn = window.location.pathname.startsWith('/en');

    try {
      const res = await fetch('/api/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: chatUserId, name, email, text })
      });
      if (res.ok) {
        // Reload from server to get correct message IDs
        loadMessages();
      } else {
        chatHistory = chatHistory.filter(m => m.id !== tempMsg.id);
        renderMessages();
        msgInput.value = text;
        alert(isEn ? 'Message could not be sent. Please contact us via WhatsApp.' : 'Mesajınız iletilemedi. Lütfen WhatsApp üzerinden iletişime geçin.');
      }
    } catch {
      chatHistory = chatHistory.filter(m => m.id !== tempMsg.id);
      renderMessages();
      msgInput.value = text;
      alert(isEn ? 'Connection error. Please contact us via WhatsApp.' : 'Bağlantı hatası. Lütfen WhatsApp üzerinden iletişime geçin.');
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  msgInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // Polling for replies
  function startPolling() {
    stopPolling();
    pollInterval = setInterval(async () => {
      try {
        const res = await fetch(`/api/messages?userId=${chatUserId}`);
        if (res.ok) {
          const data = await res.json();
          const nextHistory = data.messages || [];
          if (nextHistory.length > chatHistory.length) {
            chatHistory = nextHistory;
            renderMessages();
          }
        }
      } catch {}
    }, 15000); // Poll every 15 seconds when open
  }

  function stopPolling() {
    if (pollInterval) {
      clearInterval(pollInterval);
      pollInterval = null;
    }
  }

  // Background poll for notification badge when closed
  setInterval(async () => {
    if (isPanelOpen) return;
    try {
      const res = await fetch(`/api/messages?userId=${chatUserId}`);
      if (res.ok) {
        const data = await res.json();
        const nextHistory = data.messages || [];
        const adminReplies = nextHistory.filter((m: any) => m.sender === 'admin').length;
        const currentAdminReplies = chatHistory.filter(m => m.sender === 'admin').length;
        
        if (adminReplies > currentAdminReplies) {
          unreadReplies = adminReplies - currentAdminReplies;
          badge.textContent = String(unreadReplies);
          badge.style.display = 'grid';
        }
      }
    } catch {}
  }, 60000); // Check once a minute when closed
</script>
