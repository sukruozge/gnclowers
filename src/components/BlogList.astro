---
import { loadPosts, splitCover, categoryLabel, type Post } from '@lib/blog';
import type { Locale } from '@lib/i18n';

interface Props { locale: Locale }
const { locale } = Astro.props as Props;
const isTr = locale === 'tr';

const L = isTr
  ? { eyebrow: 'atölye günlüğü', title: 'Blog', sub: 'Amigurumi, güvenli oyuncaklar, organik iplik ve atölyemizden hikâyeler.',
      readMore: 'Devamını oku', all: 'Tümü', featured: 'Öne çıkan' }
  : { eyebrow: 'the workshop journal', title: 'Journal', sub: 'Amigurumi, safe toys, organic yarn and stories from our workshop.',
      readMore: 'Read more', all: 'All', featured: 'Featured' };

// Warm, brand-harmonious category colors (muted, professional — not garish).
const CAT_COLORS = ['#B0532E', '#C4892E', '#6E7B57', '#B5677A', '#5B7C8A', '#8A6BA0'];
function catColor(cat: string): string {
  let h = 0;
  for (let i = 0; i < cat.length; i++) h = (h * 31 + cat.charCodeAt(i)) >>> 0;
  return CAT_COLORS[h % CAT_COLORS.length];
}

const fmt = (d: string) =>
  new Intl.DateTimeFormat(isTr ? 'tr-TR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));

const items = loadPosts().map((p: Post) => ({
  href: `/${locale}/blog/${p.slug}`,
  title: isTr ? p.title_tr : p.title_en,
  excerpt: isTr ? p.excerpt_tr : p.excerpt_en,
  cover: p.cover || splitCover(isTr ? p.bodyHtml_tr : p.bodyHtml_en).cover || '/hero.png',
  category: p.category || (isTr ? 'Günlük' : 'Journal'),
  date: fmt(p.date),
}));

const [featured, ...rest] = items;
const categories = [...new Set(items.map((i) => i.category))];
---
<section class="bloglist">
  <!-- Full-width animated hero: two kids + floating stickers + self-stitching chain -->
  <header class="bl__hero">
    <img class="kid kid--girl" src="/images/kid-girl.png" alt="" width="896" height="1200" fetchpriority="high" />
    <img class="kid kid--boy" src="/images/kid-boy.png" alt="" width="896" height="1200" fetchpriority="high" />

    <div class="bl__stickers" aria-hidden="true">
      <span class="fl" style="--x:26%; --y:16%; --d:6s;   --r:-12deg; --depth:24">🧶</span>
      <span class="fl" style="--x:72%; --y:14%; --d:7.2s; --r:10deg;  --depth:32">⭐</span>
      <span class="fl" style="--x:49%; --y:7%;  --d:8s;   --r:6deg;   --depth:16">🎀</span>
      <span class="fl" style="--x:63%; --y:30%; --d:6.4s; --r:13deg;  --depth:28">💛</span>
    </div>

    <div class="bl__inner">
      <p class="bl__eyebrow">{L.eyebrow}</p>
      <h1 class="bl__title">
        {L.title.split('').map((ch, i) => (
          <span class="ltr" style={`--i:${i}`}>{ch}</span>
        ))}
      </h1>
      <svg class="bl__stitch" viewBox="0 0 240 16" preserveAspectRatio="none" aria-hidden="true">
        <path d="M4 8c8-9 18-9 26 0s18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0 18 9 26 0 18-9 26 0" />
      </svg>
      <p class="bl__sub">{L.sub}</p>

      <!-- Language tabs -->
      <div class="tabs" role="tablist" aria-label="Dil / Language">
        <a class="tab" href="/tr/blog" aria-current={isTr ? 'page' : undefined}>🇹🇷 Türkçe</a>
        <a class="tab" href="/en/blog" aria-current={!isTr ? 'page' : undefined}>🇬🇧 English</a>
      </div>
    </div>
  </header>

  {featured && (
    <a class="feat" href={featured.href} style={`--cat:${catColor(featured.category)}`}>
      <span class="feat__img"><img src={featured.cover} alt={featured.title} fetchpriority="high" /></span>
      <span class="feat__panel">
        <span class="feat__tag">★ {L.featured}</span>
        <span class="row">
          <span class="chip">{categoryLabel(featured.category, locale)}</span>
          <span class="date">{featured.date}</span>
        </span>
        <h2 class="feat__title">{featured.title}</h2>
        <p class="feat__ex">{featured.excerpt}</p>
        <span class="feat__more">{L.readMore} →</span>
      </span>
    </a>
  )}

  {categories.length > 1 && (
    <div class="filters" role="group" aria-label="Kategori">
      <button class="fbtn is-active" data-cat="*">{L.all}</button>
      {categories.map((c) => (
        <button class="fbtn" data-cat={c} style={`--cat:${catColor(c)}`}>{categoryLabel(c, locale)}</button>
      ))}
    </div>
  )}

  <div class="grid">
    {rest.map((p) => (
      <a class="card" href={p.href} data-cat={p.category} style={`--cat:${catColor(p.category)}`}>
        <span class="card__img"><img src={p.cover} alt={p.title} loading="lazy" /></span>
        <span class="card__body">
          <span class="row">
            <span class="chip">{categoryLabel(p.category, locale)}</span>
            <span class="date">{p.date}</span>
          </span>
          <span class="card__title">{p.title}</span>
          <span class="card__ex">{p.excerpt}</span>
          <span class="card__more">{L.readMore} →</span>
        </span>
      </a>
    ))}
  </div>
</section>

<style>
  .bloglist { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--space-5) var(--space-8); }

  /* Full-width animated hero */
  .bl__hero { position: relative; overflow: hidden;
    width: 100vw; margin-left: calc(50% - 50vw); border-radius: 0;
    min-height: clamp(440px, 60vh, 600px); margin-bottom: var(--space-7);
    display: grid; place-items: center; isolation: isolate;
    background: radial-gradient(115% 100% at 50% -10%, #FCEBDD 0%, #FBF3EA 45%, var(--bg) 100%); }

  /* Children illustrations */
  .kid { position: absolute; bottom: 0; z-index: 0; height: clamp(240px, 40vw, 500px); width: auto;
    filter: drop-shadow(0 14px 22px rgba(28,26,24,.18));
    translate: var(--kx, 0) var(--ky, 0); will-change: transform, translate; }
  .kid--girl { left: clamp(-16px, 3vw, 70px); animation: swayL 5s ease-in-out infinite; }
  .kid--boy { right: clamp(-16px, 3vw, 70px); animation: swayR 5.6s ease-in-out infinite; }
  @keyframes swayL { 0%, 100% { transform: rotate(-1.6deg); } 50% { transform: rotate(1.4deg) translateY(-6px); } }
  @keyframes swayR { 0%, 100% { transform: rotate(1.6deg); } 50% { transform: rotate(-1.4deg) translateY(-6px); } }
  @media (max-width: 920px) { .kid { height: clamp(180px, 30vw, 300px); opacity: .5; } }
  @media (max-width: 680px) { .kid { display: none; } }
  .bl__hero::before { content: ""; position: absolute; inset: -20%; z-index: -2;
    background: radial-gradient(38% 38% at 28% 30%, rgba(220,160,55,.16), transparent 70%),
                radial-gradient(44% 44% at 76% 62%, rgba(176,83,46,.13), transparent 70%);
    animation: drift 16s ease-in-out infinite alternate; }
  @keyframes drift { from { transform: translate(-3%, -2%) scale(1); } to { transform: translate(3%, 2%) scale(1.08); } }

  .bl__stickers { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .fl { position: absolute; left: var(--x); top: var(--y); font-size: clamp(1.7rem, 3.6vw, 3rem);
    transform: translate(var(--px, 0), var(--py, 0)) rotate(var(--r));
    animation: floaty var(--d) ease-in-out infinite; filter: drop-shadow(0 8px 12px rgba(28,26,24,.14));
    transition: transform 300ms ease-out; will-change: transform; }
  @keyframes floaty { 0%, 100% { translate: 0 0; } 50% { translate: 0 -16px; } }

  .bl__inner { position: relative; z-index: 1; text-align: center; max-width: 42rem; padding: var(--space-7) var(--space-5); }
  .bl__eyebrow { font-family: var(--font-signature); font-size: 1.85rem; color: var(--accent); margin: 0 0 var(--space-1); transform: rotate(-2deg); opacity: 0; animation: rise .6s var(--ease) .1s forwards; }
  .bl__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(3rem, 7vw, 4.6rem); line-height: 1; color: var(--ink); margin: 0 0 var(--space-2); }
  .bl__title .ltr { display: inline-block; opacity: 0; animation: pop .5s var(--ease) both; animation-delay: calc(var(--i) * 70ms + 300ms); }
  .bl__stitch { display: block; width: 132px; height: 16px; margin: 0 auto var(--space-4); overflow: visible; }
  .bl__stitch path { fill: none; stroke: var(--accent); stroke-width: 3; stroke-linecap: round;
    stroke-dasharray: 600; stroke-dashoffset: 600; animation: stitch 2.2s ease-in-out .9s forwards; }
  .bl__sub { color: var(--muted); font-size: 1.12rem; line-height: 1.6; margin: 0 auto var(--space-4); max-width: 34rem; opacity: 0; animation: rise .6s var(--ease) .5s forwards; }

  @keyframes rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
  @keyframes pop { 0% { opacity: 0; transform: translateY(22px) scale(.8) rotate(-6deg); } 100% { opacity: 1; transform: none; } }
  @keyframes stitch { to { stroke-dashoffset: 0; } }

  /* Language tabs */
  .tabs { display: inline-flex; gap: 4px; padding: 5px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-pill); box-shadow: var(--shadow-glass); opacity: 0; animation: rise .6s var(--ease) .7s forwards; }
  .tab { padding: 8px 20px; border-radius: var(--radius-pill); font-size: .92rem; font-weight: 600; color: var(--muted); text-decoration: none; transition: all var(--dur) var(--ease); }
  .tab:hover { color: var(--accent-ink); }
  .tab[aria-current="page"] { background: var(--accent); color: var(--on-accent); }

  @media (prefers-reduced-motion: reduce) {
    .bl__hero::before, .fl, .kid { animation: none; }
    .bl__eyebrow, .bl__title .ltr, .bl__sub, .tabs { opacity: 1; animation: none; }
    .bl__stitch path { stroke-dashoffset: 0; animation: none; }
  }

  /* Shared chip + date */
  .row { display: flex; align-items: center; gap: var(--space-3); }
  .chip { font-family: var(--font-body); font-size: .72rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
    color: var(--cat, var(--accent)); background: color-mix(in srgb, var(--cat, var(--accent)) 14%, transparent);
    padding: 4px 11px; border-radius: var(--radius-pill); white-space: nowrap; }
  .date { font-size: var(--step-small); color: var(--muted); letter-spacing: .02em; }

  /* Featured */
  .feat { display: grid; grid-template-columns: 1.15fr 1fr; gap: 0; margin-bottom: var(--space-7);
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden;
    text-decoration: none; transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  .feat:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .feat__img { position: relative; overflow: hidden; min-height: 320px; background: var(--section); }
  .feat__img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 700ms var(--ease); }
  .feat:hover .feat__img img { transform: scale(1.04); }
  .feat__panel { padding: var(--space-7) var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); align-self: center; }
  .feat__tag { font-family: var(--font-body); font-size: .74rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--star-gold); }
  .feat__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.5rem, 2.6vw, 2.1rem); line-height: 1.15; color: var(--ink); margin: 0; }
  .feat__ex { color: var(--muted); line-height: 1.6; margin: 0; }
  .feat__more { color: var(--accent-ink); font-weight: 600; margin-top: var(--space-2); }
  @media (max-width: 780px) { .feat { grid-template-columns: 1fr; } .feat__img { min-height: 220px; } .feat__panel { padding: var(--space-6) var(--space-5); } }

  /* Filters */
  .filters { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-6); }
  .fbtn { font-family: var(--font-body); font-size: .82rem; font-weight: 600; cursor: pointer;
    color: var(--muted); background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-pill);
    padding: 8px 16px; transition: all var(--dur) var(--ease); }
  .fbtn:hover { border-color: var(--cat, var(--accent)); color: var(--cat, var(--accent-ink)); }
  .fbtn.is-active { color: var(--on-accent); background: var(--cat, var(--accent)); border-color: transparent; }

  /* Grid cards */
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(288px, 1fr)); gap: var(--space-5); perspective: 1200px; }
  .card { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius-lg); overflow: hidden; text-decoration: none;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease); }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); border-color: color-mix(in srgb, var(--cat, var(--accent)) 40%, var(--line)); }
  .card__img { display: block; aspect-ratio: 3 / 2; overflow: hidden; background: var(--section); border-bottom: 3px solid var(--cat, var(--accent)); }
  .card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms var(--ease); }
  .card:hover .card__img img { transform: scale(1.06); }
  .card__body { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
  .card__title { font-family: var(--font-display); font-weight: 600; font-size: 1.28rem; line-height: 1.22; color: var(--ink); text-wrap: pretty; }
  .card__ex { color: var(--muted); font-size: .96rem; line-height: 1.55; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card__more { color: var(--accent-ink); font-weight: 600; font-size: .92rem; margin-top: auto; }

  @media (prefers-reduced-motion: reduce) {
    .feat:hover, .card:hover { transform: none; }
    .feat:hover .feat__img img, .card:hover .card__img img { transform: none; }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLElement>('.fbtn');
  const cards = document.querySelectorAll<HTMLElement>('.card[data-cat]');
  btns.forEach((b) => b.addEventListener('click', () => {
    btns.forEach((x) => x.classList.remove('is-active'));
    b.classList.add('is-active');
    const cat = b.dataset.cat;
    cards.forEach((c) => { c.style.display = cat === '*' || c.dataset.cat === cat ? '' : 'none'; });
  }));

  // Mouse-follow 3D tilt on cards (desktop, motion-safe)
  const bigScreen = window.matchMedia('(min-width: 781px)').matches;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (bigScreen && !reduce) {
    document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `translateY(-6px) rotateX(${y * -5}deg) rotateY(${x * 6}deg)`;
      }, { passive: true });
      card.addEventListener('mouseleave', () => { card.style.transform = ''; });
    });

    // Hero mouse parallax: floating stickers + the two kids
    const hero = document.querySelector<HTMLElement>('.bl__hero');
    const stickers = document.querySelectorAll<HTMLElement>('.fl');
    const kids = document.querySelectorAll<HTMLElement>('.kid');
    if (hero && (stickers.length || kids.length)) {
      hero.addEventListener('mousemove', (e) => {
        const r = hero.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        stickers.forEach((s) => {
          const depth = parseFloat(s.style.getPropertyValue('--depth')) || 20;
          s.style.setProperty('--px', (x * depth).toFixed(1) + 'px');
          s.style.setProperty('--py', (y * depth).toFixed(1) + 'px');
        });
        kids.forEach((k) => {
          k.style.setProperty('--kx', (x * 16).toFixed(1) + 'px');
          k.style.setProperty('--ky', (y * 9).toFixed(1) + 'px');
        });
      }, { passive: true });
      hero.addEventListener('mouseleave', () => {
        stickers.forEach((s) => { s.style.setProperty('--px', '0px'); s.style.setProperty('--py', '0px'); });
        kids.forEach((k) => { k.style.setProperty('--kx', '0px'); k.style.setProperty('--ky', '0px'); });
      });
    }
  }
</script>
