---
interface Props { href?: string; variant?: 'primary' | 'outline'; external?: boolean; id?: string; class?: string; }
const { href, variant = 'primary', external = false, id, class: className = '' } = Astro.props;
const rel = external ? 'noopener' : undefined;
const target = external ? '_blank' : undefined;
---
{href ? (
  <a class={`btn btn--${variant} ${className}`} href={href} target={target} rel={rel} id={id}><slot /></a>
) : (
  <button class={`btn btn--${variant} ${className}`} id={id} type="button"><slot /></button>
)}
<style>
  .btn { display: inline-block; font-size: .95rem; font-weight: 500; letter-spacing: .02em; padding: 13px 26px; border-radius: var(--radius-pill); border: none; cursor: pointer; font-family: inherit; transition: transform var(--dur) var(--ease), background var(--dur) var(--ease), color var(--dur) var(--ease); text-align: center; }
  .btn:hover { transform: translateY(-2px); }
  .btn--primary { background: var(--accent); color: var(--on-accent); }
  .btn--primary:hover { background: var(--accent-ink); }
  .btn--outline { border: 1px solid var(--ink); color: var(--ink); background: transparent; }
  .btn--outline:hover { background: var(--ink); color: var(--bg); }
</style>

