---
interface Props { mode?: 'full' | 'mark'; class?: string; }
const { mode = 'full', class: cls = '' } = Astro.props;
---
<span class={`logo logo--${mode} ${cls}`}>
  <svg class="logo__mark" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Aselovers">
    <circle cx="60" cy="60" r="56" fill="var(--blush)" />
    <!-- crescent moon carved out of the disc -->
    <mask id="crescent"><rect width="120" height="120" fill="#fff" /><circle cx="80" cy="38" r="36" fill="#000" /></mask>
    <circle cx="54" cy="62" r="42" fill="#FFF" mask="url(#crescent)" />
    <!-- sleeping baby nestled in the lower curve of the crescent -->
    <g fill="var(--blush)">
      <circle cx="38" cy="76" r="13" />
      <path d="M47 82c9 .5 17 5.5 19.5 13 1.2 3.6-2 6-5.2 4.2-4.6-2.6-10-4.3-16-4.9-4.3-.4-5.3-4.2-3.5-7.3 1.4-2.5 3.2-4.7 5.2-5z" />
    </g>
    <path d="M33 75.3c1.7 1.4 3.5 1.4 5.2 0" stroke="#FFF" stroke-width="1.6" stroke-linecap="round" fill="none" />
  </svg>
  
  {mode === 'full' && (
    <span class="logo__type">
      <span class="logo__word-container">
        <!-- Floating hearts decoration left -->
        <span class="logo__decor logo__decor--left">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--blush)" opacity="0.8">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </span>
        <span class="logo__word">Aselovers</span>
        <!-- Floating hearts decoration right -->
        <span class="logo__decor logo__decor--right">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--blush)" opacity="0.8">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </span>
      </span>
      <span class="logo__tag-container">
        <span class="logo__sweep logo__sweep--left">~~</span>
        <span class="logo__tag">Personalized Baby Gifts</span>
        <span class="logo__sweep logo__sweep--right">~~</span>
      </span>
    </span>
  )}
</span>
<style>
  .logo { display: inline-flex; align-items: center; gap: var(--space-3); }
  .logo__mark { width: 44px; height: 44px; flex: none; }
  .logo__type { display: flex; flex-direction: column; align-items: center; text-align: center; line-height: 1; }
  
  .logo__word-container {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
  }
  .logo__word { 
    font-family: 'Dancing Script', cursive; 
    font-weight: 700; 
    font-size: 1.95rem; 
    color: var(--ink); 
    z-index: 2;
  }
  
  /* Hearts decorations */
  .logo__decor {
    position: absolute;
    pointer-events: none;
    z-index: 1;
  }
  .logo__decor--left {
    top: -8px;
    left: -12px;
    transform: rotate(-15deg);
  }
  .logo__decor--right {
    bottom: -2px;
    right: -10px;
    transform: rotate(20deg);
  }
  
  /* Subtitle container with swooshes */
  .logo__tag-container {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: -2px;
  }
  .logo__sweep {
    font-family: 'Dancing Script', cursive;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--blush);
    letter-spacing: -2px;
    opacity: 0.8;
    user-select: none;
  }
  .logo__tag { 
    font-size: .52rem; 
    font-weight: 600;
    letter-spacing: .12em; 
    text-transform: uppercase; 
    color: var(--muted); 
  }
</style>
