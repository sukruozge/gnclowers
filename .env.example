# ASELOVERS — Sunucu Ayarları
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   cp .env.example .env
#
# .env dosyasını asla git'e commit ETMEYİN!

# ── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Admin Girişi ──────────────────────────────────────
# Kullanıcı adı
ADMIN_USERNAME=admin

# Şifre — ikisinden birini kullanın:
#   A) Düz metin (geliştirme için) — başlangıçta hash'lenir
#   ⚠️ Aşağıdaki değer yalnızca örnektir; GERÇEK şifrenizle DEĞİŞTİRİN.
ADMIN_PASSWORD=CHANGE_ME_choose_a_strong_password
#   B) Önerilen: bcrypt hash (production için)
#      Oluşturmak için: node -e "require('bcryptjs').hash('YeniSifre!', 12).then(h => console.log(h))"
# ADMIN_PASSWORD_HASH=$2a$12$...

# ── JWT ──────────────────────────────────────────────
# Rastgele 64 byte hex — production'da MUTLAKA ayarlayın!
# Oluşturmak için: node -e "require('crypto').randomBytes(64).then ? '' : console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_byte_hex_string

# ── Etsy ─────────────────────────────────────────────
# https://www.etsy.com/developers adresinden API key alın
ETSY_API_KEY=your_etsy_keystring_here

# Etsy mağaza adınız
ETSY_SHOP=aselovers

# ── PayTR Sanal POS ──────────────────────────────────
# PayTR üye iş yeri ID, Key ve Salt değerleri
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt
PAYTR_TEST_MODE=1

# ── Cloudflare Pages ortam değişkenleri ──────────────
# Bunlar Cloudflare dashboard'da (Settings → Environment variables) tanımlanır;
# kod locals.runtime.env üzerinden okur. Buraya sadece belge amaçlı yazıldı.
# Sitenin tam URL'i (PayTR ok/fail dönüş adresleri için)
SITE_URL=https://aseloves.com
# Admin panel yazma erişimi: fine-grained PAT, yalnızca deploy deposuna Contents:write
GITHUB_TOKEN=
# Admin yazmalarının hedef deposu (Cloudflare'in build aldığı depo ile AYNI olmalı)
GITHUB_REPO=sukruozge/gnclowers
# ADMIN_KV: wrangler.toml'daki KV binding'i (dashboard'da otomatik bağlanır)

# ── GitHub Actions secrets (workflow'larda kullanılır) ─
# etsy-sync.yml: ETSY_API_KEY, ETSY_REFRESH_TOKEN, DEEPL_API_KEY
# Etsy OAuth refresh token ~90 günde bir yenilenmeli (npm run etsy-auth)
ETSY_REFRESH_TOKEN=
DEEPL_API_KEY=

